---
interface Props {
  lang?: "ru" | "en";
}
const { lang = "ru" } = Astro.props;

const copy = lang === "ru"
  ? {
      eyebrow: "Экспедиционный проект · 2026",
      title: "Expedition 65",
      subtitle: "Lux",
      specs: [
        { label: "Длина", value: "19,6", unit: "м" },
        { label: "Каюты", value: "5", unit: "" },
        { label: "Гостей", value: "12", unit: "" },
        { label: "Сезоны", value: "4", unit: "до −30 °C" },
        { label: "Корпус", value: "Сталь", unit: "нерж." },
        { label: "Год", value: "2026", unit: "" },
      ],
      tagline: "Право на свободу маршрута.",
      primary: "Запросить стоимость",
      secondary: "Спецификация",
      heroAlt: "Expedition 65 Lux на спокойной воде в утреннем тумане — корпус отражается в зеркальной поверхности озера",
    }
  : {
      eyebrow: "Expedition Project · 2026",
      title: "Expedition 65",
      subtitle: "Lux",
      specs: [
        { label: "Length", value: "19.6", unit: "m" },
        { label: "Cabins", value: "5", unit: "" },
        { label: "Guests", value: "12", unit: "" },
        { label: "Seasons", value: "4", unit: "to −30 °C" },
        { label: "Hull", value: "Steel", unit: "stainless" },
        { label: "Year", value: "2026", unit: "" },
      ],
      tagline: "The right to freedom of route.",
      primary: "Request Pricing",
      secondary: "Specification",
      heroAlt: "Expedition 65 Lux on calm water in morning mist — the hull mirrored on a glass-still lake",
    };
---

<section class="relative isolate w-full overflow-hidden bg-[var(--color-paper)] sm:min-h-[100svh] sm:bg-[var(--color-ink)]">
  <!-- Hero photo: Канон/Expedition/EXP_15_Calm Lake Reflection.jpeg
       Intentionally NOT wrapped in <ResponsiveImage>. The hero is the single
       highest-impact visual on the site — quality > bandwidth. Every device
       gets the full-resolution original (~1.1 MB) rather than a recompressed
       AVIF/WebP variant; the perceptible softening at AVIF q80 was not
       acceptable here. Costs ~800 KB extra on initial load; for one image
       on a luxury product page that's the right tradeoff. -->
  <div class="absolute inset-x-0 top-0 -z-10 h-[52vh] overflow-hidden sm:inset-0 sm:h-auto">
    <img
      src="hero/hero.jpg"
      alt={copy.heroAlt}
      width={3200}
      height={1786}
      loading="eager"
      fetchpriority="high"
      decoding="sync"
      class="absolute inset-0 h-full w-full origin-center scale-150 translate-x-[8%] object-cover sm:translate-x-[15%]"
    />
    <!-- Dark gradient overlay — keeps the glass card legible on the left. -->
    <div
      class="absolute inset-0"
      style="background:
        linear-gradient(110deg,
          rgba(0,0,0,0.55) 0%,
          rgba(0,0,0,0.3) 35%,
          rgba(0,0,0,0.05) 65%,
          rgba(0,0,0,0.2) 100%);"
    ></div>
  </div>

  <div class="mx-auto flex max-w-[1440px] items-start px-6 pb-6 pt-[calc(52vh+1rem)] sm:min-h-[100svh] sm:items-end sm:px-8 sm:pb-16 sm:pt-36 lg:items-center">
    <div class="grid w-full grid-cols-12 gap-8">
      <!-- Bering-70 style translucent card, pinned left -->
      <div class="col-span-12 sm:col-span-10 md:col-span-7 lg:col-span-5 xl:col-span-5">
        <div
          class="p-0 sm:rounded-[2px] sm:border sm:border-[color-mix(in_srgb,white_15%,transparent)] sm:bg-[color-mix(in_srgb,black_55%,transparent)] sm:p-10 sm:backdrop-blur-xl"
        >
          <p class="hidden text-[11px] uppercase tracking-[var(--tracking-wide-cap)] text-[color-mix(in_srgb,black_60%,transparent)] sm:block sm:text-[color-mix(in_srgb,white_70%,transparent)]">
            {copy.eyebrow}
          </p>

          <div class="mt-0 flex flex-wrap items-baseline gap-x-3 gap-y-1 sm:mt-6">
            <h1 class="display whitespace-nowrap text-[34px] leading-[0.95] text-[var(--color-ink)] sm:text-[52px] sm:text-[var(--color-paper)]">
              {copy.title}
            </h1>
            <span class="text-[18px] font-light italic tracking-tight text-[color-mix(in_srgb,black_55%,transparent)] sm:text-[24px] sm:text-[color-mix(in_srgb,white_75%,transparent)]">
              {copy.subtitle}
            </span>
          </div>

          <!-- Spec grid 3x2 -->
          <dl class="mt-4 grid grid-cols-3 gap-x-4 gap-y-4 sm:mt-6 sm:grid-cols-2 sm:gap-x-6 sm:gap-y-5 sm:border-t sm:border-[color-mix(in_srgb,white_15%,transparent)] sm:pt-6">
            {copy.specs.map((s) => (
              <div class="text-center sm:text-left">
                <dt class="text-[10px] font-semibold uppercase tracking-[var(--tracking-cap)] text-[color-mix(in_srgb,black_60%,transparent)] sm:text-[color-mix(in_srgb,white_70%,transparent)]">
                  {s.label}
                </dt>
                <dd class="mt-1 text-[18px] font-light leading-none tracking-[-0.02em] text-[var(--color-ink)] sm:text-[26px] sm:text-[var(--color-paper)]">
                  {s.value}
                  {s.unit && !s.unit.includes("°") && !s.unit.includes("экипаж") && !s.unit.includes("crew") && !s.unit.includes("суток") && !s.unit.includes("days") && !s.unit.includes("нерж") && !s.unit.includes("stainless") && (
                    <span class="text-[14px] text-[color-mix(in_srgb,black_45%,transparent)] sm:text-[color-mix(in_srgb,white_55%,transparent)]"> {s.unit}</span>
                  )}
                </dd>
                {s.unit && (s.unit.includes("°") || s.unit.includes("экипаж") || s.unit.includes("crew") || s.unit.includes("суток") || s.unit.includes("days") || s.unit.includes("нерж") || s.unit.includes("stainless")) && (
                  <dd class="mt-1 text-[10px] uppercase tracking-[var(--tracking-cap)] text-[color-mix(in_srgb,black_45%,transparent)] sm:text-[color-mix(in_srgb,white_55%,transparent)]">
                    {s.unit}
                  </dd>
                )}
              </div>
            ))}
          </dl>

          <p class="display mt-8 hidden text-[18px] italic text-[color-mix(in_srgb,black_65%,transparent)] sm:block sm:text-[color-mix(in_srgb,white_80%,transparent)]">
            {copy.tagline}
          </p>

          <div class="mt-7 flex items-center gap-3 sm:flex-wrap">
            <a
              href="#inquire"
              class="inline-flex items-center gap-2 whitespace-nowrap rounded-full bg-[var(--color-ink)] px-4 py-2.5 text-[10px] uppercase tracking-[var(--tracking-cap)] text-[var(--color-paper)] transition-colors hover:bg-[var(--color-neon-blue)] hover:text-[var(--color-paper)] sm:bg-[var(--color-paper)] sm:px-6 sm:py-3 sm:text-[11px] sm:text-[var(--color-ink)]"
            >
              {copy.primary}
            </a>
            <a
              href="#spec"
              class="inline-flex items-center gap-2 whitespace-nowrap rounded-full border border-[color-mix(in_srgb,black_45%,transparent)] px-4 py-2.5 text-[10px] uppercase tracking-[var(--tracking-cap)] text-[var(--color-ink)] transition-[border-color,box-shadow] duration-200 hover:border-[var(--color-neon-blue)] hover:[box-shadow:inset_0_0_0_3px_var(--color-neon-blue)] sm:border-[color-mix(in_srgb,white_45%,transparent)] sm:px-6 sm:py-3 sm:text-[11px] sm:text-[var(--color-paper)]"
            >
              {copy.secondary}
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll cue, bottom-center -->
  <div class="pointer-events-none absolute inset-x-0 bottom-6 hidden justify-center sm:flex">
    <div class="flex flex-col items-center gap-2">
      <span class="text-[10px] uppercase tracking-[var(--tracking-wide-cap)] text-[color-mix(in_srgb,white_50%,transparent)]">
        {lang === "ru" ? "Маршрут вниз" : "Scroll"}
      </span>
      <div class="h-8 w-px bg-[color-mix(in_srgb,white_25%,transparent)]"></div>
    </div>
  </div>
</section>
