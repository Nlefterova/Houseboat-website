---
interface Props {
  lang?: "ru" | "en";
}
const { lang = "ru" } = Astro.props;

const copy = lang === "ru"
  ? {
      eyebrow: "KARTEL · Экспедиционный проект",
      title: "Expedition 65",
      subtitle: "Lux",
      meta: [
        { label: "Серия", value: "Lux" },
        { label: "Год", value: "2026" },
      ],
      specs: [
        { label: "Длина", value: "19,6", unit: "м" },
        { label: "Каюты", value: "5", unit: "" },
        { label: "Гостей", value: "12", unit: "" },
        { label: "Сезоны", value: "4", unit: "до −30 °C" },
        { label: "Корпус", value: "Сталь", unit: "нерж." },
        { label: "Автономия", value: "7+", unit: "суток" },
      ],
      tagline: "Право на свободу маршрута.",
      primary: "Запросить стоимость",
      secondary: "Спецификация",
    }
  : {
      eyebrow: "KARTEL · Expedition Project",
      title: "Expedition 65",
      subtitle: "Lux",
      meta: [
        { label: "Series", value: "Lux" },
        { label: "Year", value: "2026" },
      ],
      specs: [
        { label: "Length", value: "19.6", unit: "m" },
        { label: "Cabins", value: "5", unit: "" },
        { label: "Guests", value: "12", unit: "" },
        { label: "Seasons", value: "4", unit: "to −30 °C" },
        { label: "Hull", value: "Steel", unit: "stainless" },
        { label: "Autonomy", value: "7+", unit: "days" },
      ],
      tagline: "The right to freedom of route.",
      primary: "Request Pricing",
      secondary: "Specification",
    };
---

<section class="relative isolate min-h-[100svh] w-full overflow-hidden bg-[var(--color-ink)]">
  <!-- Hero photo: Канон/Expedition/EXP_15_Calm Lake Reflection.jpeg
       TODO: swap to 4K upscaled version once we run the batch through Topaz. -->
  <div class="absolute inset-0 -z-10">
    <img
      src="/hero/hero.jpg"
      alt=""
      class="absolute inset-0 h-full w-full object-cover"
      style="transform: scale(1.5) translateX(15%); transform-origin: center;"
      loading="eager"
      fetchpriority="high"
    />
    <!-- Dark gradient overlay — keeps the glass card legible on the left. -->
    <div
      class="absolute inset-0"
      style="background:
        linear-gradient(110deg,
          rgba(0,0,0,0.55) 0%,
          rgba(0,0,0,0.3) 35%,
          rgba(0,0,0,0.05) 65%,
          rgba(0,0,0,0.2) 100%);"
    ></div>
  </div>

  <div class="mx-auto flex min-h-[100svh] max-w-[1440px] items-end px-8 pb-16 pt-36 lg:items-center">
    <div class="grid w-full grid-cols-12 gap-8">
      <!-- Bering-70 style translucent card, pinned left -->
      <div class="col-span-12 sm:col-span-10 md:col-span-7 lg:col-span-5 xl:col-span-5">
        <div
          class="rounded-[2px] border border-[color-mix(in_srgb,white_15%,transparent)] bg-[color-mix(in_srgb,black_55%,transparent)] p-8 backdrop-blur-xl sm:p-10"
        >
          <p class="text-[11px] uppercase tracking-[var(--tracking-wide-cap)] text-[color-mix(in_srgb,white_70%,transparent)]">
            {copy.eyebrow}
          </p>

          <div class="mt-6 flex flex-wrap items-baseline gap-x-3 gap-y-1">
            <h1 class="display whitespace-nowrap text-[40px] leading-[0.95] text-[var(--color-paper)] sm:text-[52px]">
              {copy.title}
            </h1>
            <span class="text-[20px] font-light italic tracking-tight text-[color-mix(in_srgb,white_75%,transparent)] sm:text-[24px]">
              {copy.subtitle}
            </span>
          </div>

          <!-- Bering pattern: small label/value meta row (Name+Year / Series+Year) -->
          <dl class="mt-6 grid grid-cols-2 gap-x-6 gap-y-3 border-t border-[color-mix(in_srgb,white_15%,transparent)] pt-6">
            {copy.meta.map((m) => (
              <div>
                <dt class="text-[10px] font-semibold uppercase tracking-[var(--tracking-cap)] text-[color-mix(in_srgb,white_70%,transparent)]">
                  {m.label}
                </dt>
                <dd class="mt-1 text-[16px] text-[var(--color-paper)]">{m.value}</dd>
              </div>
            ))}
          </dl>

          <!-- Spec grid 3x2 -->
          <dl class="mt-6 grid grid-cols-2 gap-x-6 gap-y-5 border-t border-[color-mix(in_srgb,white_15%,transparent)] pt-6">
            {copy.specs.map((s) => (
              <div>
                <dt class="text-[10px] font-semibold uppercase tracking-[var(--tracking-cap)] text-[color-mix(in_srgb,white_70%,transparent)]">
                  {s.label}
                </dt>
                <dd class="mt-1 text-[26px] font-light leading-none tracking-[-0.02em] text-[var(--color-paper)]">
                  {s.value}
                  {s.unit && !s.unit.includes("°") && !s.unit.includes("экипаж") && !s.unit.includes("crew") && !s.unit.includes("суток") && !s.unit.includes("days") && !s.unit.includes("нерж") && !s.unit.includes("stainless") && (
                    <span class="text-[14px] text-[color-mix(in_srgb,white_55%,transparent)]"> {s.unit}</span>
                  )}
                </dd>
                {s.unit && (s.unit.includes("°") || s.unit.includes("экипаж") || s.unit.includes("crew") || s.unit.includes("суток") || s.unit.includes("days") || s.unit.includes("нерж") || s.unit.includes("stainless")) && (
                  <dd class="mt-1 text-[10px] uppercase tracking-[var(--tracking-cap)] text-[color-mix(in_srgb,white_55%,transparent)]">
                    {s.unit}
                  </dd>
                )}
              </div>
            ))}
          </dl>

          <p class="display mt-8 text-[18px] italic text-[color-mix(in_srgb,white_80%,transparent)]">
            {copy.tagline}
          </p>

          <div class="mt-7 flex flex-wrap items-center gap-3">
            <a
              href="#inquire"
              class="inline-flex items-center gap-2 rounded-full bg-[var(--color-paper)] px-6 py-3 text-[11px] uppercase tracking-[var(--tracking-cap)] text-[var(--color-ink)] transition-colors hover:bg-[var(--color-light-grey)]"
            >
              {copy.primary}
            </a>
            <a
              href="#spec"
              class="inline-flex items-center gap-2 rounded-full border border-[color-mix(in_srgb,white_45%,transparent)] px-6 py-3 text-[11px] uppercase tracking-[var(--tracking-cap)] text-[var(--color-paper)] transition-colors hover:border-[var(--color-paper)] hover:bg-[color-mix(in_srgb,white_8%,transparent)]"
            >
              {copy.secondary}
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll cue, bottom-center -->
  <div class="pointer-events-none absolute inset-x-0 bottom-6 flex justify-center">
    <div class="flex flex-col items-center gap-2">
      <span class="text-[10px] uppercase tracking-[var(--tracking-wide-cap)] text-[color-mix(in_srgb,white_50%,transparent)]">
        {lang === "ru" ? "Маршрут вниз" : "Scroll"}
      </span>
      <div class="h-8 w-px bg-[color-mix(in_srgb,white_25%,transparent)]"></div>
    </div>
  </div>
</section>
