---
/**
 * ResponsiveImage — wraps an <img> in a <picture> that serves AVIF, WebP, or
 * JPG depending on browser support, and serves the smallest size that fits
 * the device via srcset.
 *
 * Sources live in public/, generated by scripts/generate-image-variants.mjs.
 * Given a source `hero/hero.jpg`, the script produces:
 *
 *   hero/hero-480.jpg  hero/hero-480.webp  hero/hero-480.avif
 *   hero/hero-800.jpg  hero/hero-800.webp  hero/hero-800.avif
 *   hero/hero-1200.jpg hero/hero-1200.webp hero/hero-1200.avif
 *   hero/hero-2400.jpg hero/hero-2400.webp hero/hero-2400.avif
 *
 * Pass the *original* `src` path. The helper derives the variant URLs from it.
 * Set `widths` if you used a non-default size list for this specific image.
 *
 * `sizes` is the CSS expression telling the browser how wide the image will
 * actually be rendered at each breakpoint — drives which size to pick. Default
 * "100vw" (full-bleed); narrow it for cards/columns ("(min-width: 1024px) 25vw, 50vw"
 * etc.) so phones don't grab oversized files.
 *
 * If `src` points to an SVG, the helper renders a plain <img> (vector, no
 * variants needed).
 */

interface Props {
  src: string;
  alt: string;
  width: number;
  height: number;
  sizes?: string;
  loading?: "lazy" | "eager";
  fetchpriority?: "high" | "low" | "auto";
  class?: string;
  style?: string;
  widths?: number[];
  ariaHidden?: boolean;
  id?: string;
  /** Extra data-* attributes to pass through to the inner <img>. Used by the
   *  GalleryCell tiles which carry data-* metadata read by the lightbox JS. */
  imgData?: Record<string, string | number | boolean>;
}

const {
  src,
  alt,
  width,
  height,
  sizes = "100vw",
  loading = "lazy",
  fetchpriority,
  class: className = "",
  style,
  widths = [480, 800, 1200, 2400],
  ariaHidden = false,
  id,
  imgData = {},
} = Astro.props;

const isSvg = /\.svg(\?|#|$)/i.test(src);

// Strip the original file extension (everything from the last dot).
// `hero/hero.jpg` → `hero/hero`. We append `-{w}.{ext}` to build variants.
const stem = src.replace(/\.(jpe?g|png)$/i, "");

const buildSrcset = (ext: string) =>
  widths.map((w) => `${stem}-${w}.${ext} ${w}w`).join(", ");

// Resolve `imgData` keys (camelCase ok) into `data-foo` attribute pairs.
const dataAttrs = Object.fromEntries(
  Object.entries(imgData).map(([k, v]) => [`data-${k.replace(/([A-Z])/g, "-$1").toLowerCase()}`, v])
);
---

{isSvg ? (
  <img
    src={src}
    alt={alt}
    width={width}
    height={height}
    loading={loading}
    class={className}
    style={style}
    id={id}
    aria-hidden={ariaHidden ? "true" : undefined}
    fetchpriority={fetchpriority}
    {...dataAttrs}
  />
) : (
  <picture>
    <source type="image/avif" srcset={buildSrcset("avif")} sizes={sizes} />
    <source type="image/webp" srcset={buildSrcset("webp")} sizes={sizes} />
    <img
      src={src}
      srcset={buildSrcset("jpg")}
      sizes={sizes}
      alt={alt}
      width={width}
      height={height}
      loading={loading}
      decoding="async"
      class={className}
      style={style}
      id={id}
      aria-hidden={ariaHidden ? "true" : undefined}
      fetchpriority={fetchpriority}
      {...dataAttrs}
    />
  </picture>
)}
