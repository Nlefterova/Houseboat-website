---
interface Props {
  lang?: "ru" | "en";
}
const { lang = "ru" } = Astro.props;

const copy = lang === "ru"
  ? {
      ctaEyebrow: "Начните свой маршрут",
      ctaSub: "Тест-драйв и осмотр корпуса по записи",
      ctaLabel: "Записаться на тест-драйв",
      colLocations: "Локации",
      colContacts: "Контакты",
      locations: [
        {
          name: "Москва Офис",
          mapHref: "https://yandex.ru/maps/?text=Краснопресненская+наб.+12+Москва",
          lines: [
            "Краснопресненская наб. 12",
            "6-й подъезд, 11 этаж, офис 1148",
            "Гостиница «Международная»",
          ],
        },
        {
          name: "Верфь Саратов",
          mapHref: "https://yandex.ru/maps/?text=Саратов+верфь",
          lines: ["г. Саратов, ул. Огородная, 3"],
        },
        {
          name: "Шоурум Саратов",
          mapHref: "https://yandex.ru/maps/?ll=46.081743,51.544010&z=17&pt=46.081743,51.544010",
          lines: ["г. Саратов, ул. Большая Затонская"],
        },
      ],
      phone: "+7 (495) 741-82-58",
      email: "office@kartelboats.ru",
      relatedLabel: "Связанные сайты",
      related: [
        { label: "Kartel Boats", href: "https://kartelboats.ru" },
        { label: "Корабельная Артель (верфь)", href: "https://kartelboats.ru" },
      ],
      nav: [
        { label: "Обзор", href: "#overview" },
        { label: "Экстерьер", href: "#exterior" },
        { label: "Интерьер", href: "#interior" },
        { label: "Палубы", href: "#layouts" },
        { label: "Спецификация", href: "#spec" },
        { label: "Наследие", href: "#heritage" },
        { label: "Локации", href: "#locations" },
      ],
      copyright: "© 2026 KARTEL Boats",
    }
  : {
      ctaEyebrow: "Start your route",
      ctaSub: "Sea trial and hull inspection by appointment",
      ctaLabel: "Book a sea trial",
      colLocations: "Locations",
      colContacts: "Contacts",
      locations: [
        {
          name: "Moscow Office",
          mapHref: "https://yandex.com/maps/?text=Krasnopresnenskaya+12+Moscow",
          lines: [
            "Krasnopresnenskaya emb. 12",
            "Entrance 6, floor 11, office 1148",
            "Mezhdunarodnaya Hotel",
          ],
        },
        {
          name: "Shipyard Saratov",
          mapHref: "https://yandex.com/maps/?text=Saratov+shipyard",
          lines: ["Saratov, Ogorodnaya St. 3"],
        },
        {
          name: "Showroom Saratov",
          mapHref: "https://yandex.com/maps/?ll=46.081743,51.544010&z=17&pt=46.081743,51.544010",
          lines: ["Saratov, Bolshaya Zatonskaya St."],
        },
      ],
      phone: "+7 (495) 741-82-58",
      email: "office@kartelboats.ru",
      relatedLabel: "Related sites",
      related: [
        { label: "Kartel Boats", href: "https://kartelboats.ru" },
        { label: "Shipbuilders' Artel (shipyard)", href: "https://kartelboats.ru" },
      ],
      nav: [
        { label: "Overview", href: "#overview" },
        { label: "Exterior", href: "#exterior" },
        { label: "Interior", href: "#interior" },
        { label: "Layouts", href: "#layouts" },
        { label: "Specs", href: "#spec" },
        { label: "Heritage", href: "#heritage" },
        { label: "Locations", href: "#locations" },
      ],
      copyright: "© 2026 KARTEL Boats",
    };
---

<footer class="bg-[#0b0c0a] text-[var(--color-paper)]">
  <div class="mx-auto max-w-[1200px] px-8 pb-8 pt-10">
    <!-- Top section — three columns matching Figma layout exactly. -->
    <div class="grid grid-cols-12 gap-x-10 gap-y-8">
      <!-- COL 1: KARTEL wordmark + CTA -->
      <div class="col-span-12 lg:col-span-5">
        <a href="#" aria-label="To top" class="inline-block text-[var(--color-paper)] transition-colors hover:text-[var(--color-neon-blue)]">
          <svg viewBox="173 197 300 32" fill="none" xmlns="http://www.w3.org/2000/svg" class="h-5 w-auto" aria-hidden="true">
            <path d="M471.931 228.998H427.547L434.284 197.295H440.624L435.225 222.658H473.269L471.931 228.998Z" fill="currentColor" />
            <path d="M426.605 203.636H388.561L384.499 222.658H422.543L421.206 228.998H383.162C378.935 228.998 377.267 226.885 378.159 222.658L382.221 203.636C383.112 199.408 385.672 197.295 389.899 197.295H427.943L426.605 203.636ZM423.881 216.317H392.178L393.565 209.976H425.268L423.881 216.317Z" fill="currentColor" />
            <path d="M332.833 197.295H377.218L375.88 203.636H356.858L351.459 228.998H345.118L350.518 203.636H331.496L332.833 197.295Z" fill="currentColor" />
            <path d="M281.711 228.998H275.371L282.108 197.295H320.152C324.379 197.295 326.046 199.408 325.155 203.636L323.817 209.976C322.893 214.203 320.35 216.317 316.189 216.317H309.749L319.755 228.998H311.83L301.823 216.317H290.727L292.114 209.976H317.477L318.814 203.636H287.111L281.711 228.998Z" fill="currentColor" />
            <path d="M230.986 228.998H224.645L230.045 203.636C230.937 199.408 233.496 197.295 237.723 197.295H269.426C273.653 197.295 275.321 199.408 274.43 203.636L269.03 228.998H262.689L265.364 216.317H240.002L241.389 209.976H266.751L268.089 203.636H236.386L230.986 228.998Z" fill="currentColor" />
            <path d="M186.998 197.295L180.261 228.998H173.92L180.657 197.295H186.998ZM189.97 213.147L214.738 197.295H225.042L200.274 213.147L218.305 228.998H208.001L189.97 213.147Z" fill="currentColor" />
          </svg>
        </a>
        <h3 class="mt-10 text-[18px] font-bold uppercase leading-[1.2] text-[var(--color-paper)]">
          {copy.ctaEyebrow}
        </h3>
        <p class="mt-3 text-[13px] leading-[1.2] text-[var(--color-fog)]">
          {copy.ctaSub}
        </p>
        <a
          href="#inquire"
          class="mt-5 flex h-[50px] w-[294px] items-center justify-center rounded-[6px] bg-[var(--color-neon-blue)] text-[13px] uppercase tracking-[0.04em] text-[var(--color-paper)] transition-colors hover:bg-[color-mix(in_srgb,var(--color-neon-blue)_85%,white)]"
        >
          {copy.ctaLabel}
        </a>
      </div>

      <!-- COL 2: Locations -->
      <div class="col-span-12 sm:col-span-6 lg:col-span-4">
        <p class="text-[13px] font-bold uppercase tracking-[0.04em] text-[var(--color-paper)]">
          {copy.colLocations}
        </p>
        <ul class="mt-[18px] space-y-[18px]">
          {copy.locations.map((l) => (
            <li>
              <a
                href={l.mapHref}
                target="_blank"
                rel="noopener"
                class="-ml-[5px] inline-flex items-center gap-1.5 text-[var(--color-neon-blue)] transition-colors hover:[&_p]:text-[var(--color-neon-blue)]"
              >
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" class="flex-none">
                  <path d="M12 2 C 16 2 19 5 19 9 C 19 14 12 22 12 22 C 12 22 5 14 5 9 C 5 5 8 2 12 2 Z" stroke="currentColor" stroke-width="1.6" fill="none" />
                  <circle cx="12" cy="9" r="2.5" stroke="currentColor" stroke-width="1.6" fill="none" />
                </svg>
                <p class="text-[13px] text-[var(--color-paper)] transition-colors">{l.name}</p>
              </a>
              <div class="mt-1 space-y-0.5 text-[13px] leading-[1.2] text-[var(--color-fog)]">
                {l.lines.map((line) => (
                  <p>{line}</p>
                ))}
              </div>
            </li>
          ))}
        </ul>
      </div>

      <!-- COL 3: Contacts -->
      <div class="col-span-12 sm:col-span-6 lg:col-span-3">
        <p class="text-[13px] font-bold uppercase tracking-[0.04em] text-[var(--color-paper)]">
          {copy.colContacts}
        </p>
        <ul class="mt-[18px] space-y-[16px]">
          <li>
            <a
              href={`tel:${copy.phone.replace(/[^+\d]/g, "")}`}
              class="group inline-flex items-center gap-3 text-[13px] text-[var(--color-paper)] hover:underline"
            >
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" class="flex-none text-[var(--color-neon-blue)]">
                <path d="M4 4 L7 4 L9 8 L7 10 C 8.5 13.5 10 15 13.5 16.5 L 16 14 L 20 16 L 20 19 C 20 20.5 19 21.5 17.5 21.5 C 10 21.5 2 13.5 2 6 C 2 4.5 3 4 4 4 Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" fill="none" />
              </svg>
              {copy.phone}
            </a>
          </li>
          <li>
            <a
              href={`mailto:${copy.email}`}
              class="group inline-flex items-center gap-3 text-[13px] text-[var(--color-paper)] hover:underline"
            >
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" class="flex-none text-[var(--color-neon-blue)]">
                <rect x="2" y="5" width="20" height="14" stroke="currentColor" stroke-width="1.6" rx="1" />
                <path d="M2 6 L12 13 L22 6" stroke="currentColor" stroke-width="1.6" />
              </svg>
              {copy.email}
            </a>
          </li>
        </ul>

        <div class="mt-[18px] flex items-center gap-3">
          <a
            href="https://t.me/kartelboats"
            target="_blank"
            rel="noopener"
            aria-label="Telegram"
            class="flex h-10 w-10 items-center justify-center rounded-full border border-[var(--color-neon-blue)] text-[var(--color-neon-blue)] transition-colors hover:bg-[var(--color-neon-blue)] hover:text-[var(--color-paper)]"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" class="flex-none">
              <path d="M21.5 4 L 2 9.5 L 9 12 L 12 19 L 15 14 L 19.5 17 L 21.5 4 Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" fill="none" />
            </svg>
          </a>
          <a
            href="https://www.youtube.com/@kartelboats"
            target="_blank"
            rel="noopener"
            aria-label="YouTube"
            class="flex h-10 w-10 items-center justify-center rounded-full border border-[var(--color-neon-blue)] text-[var(--color-neon-blue)] transition-colors hover:bg-[var(--color-neon-blue)] hover:text-[var(--color-paper)]"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" class="flex-none">
              <rect x="2" y="5" width="20" height="14" rx="3" stroke="currentColor" stroke-width="1.6" fill="none" />
              <path d="M10 9 L 16 12 L 10 15 Z" fill="currentColor" />
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- BOTTOM STRIP: related sites + secondary nav + copyright -->
    <hr class="mt-6 h-px border-0 bg-[color-mix(in_srgb,var(--color-paper)_15%,transparent)]" />

    <div class="mt-5 flex flex-wrap items-baseline justify-center gap-x-6 gap-y-3 text-[11px] uppercase tracking-[var(--tracking-cap)]">
      <span class="text-[var(--color-fog)]">{copy.relatedLabel}:</span>
      {copy.related.map((r) => (
        <a
          href={r.href}
          target="_blank"
          rel="noopener"
          class="group inline-flex items-center gap-1 text-[var(--color-paper)] hover:underline"
        >
          <span>{r.label}</span>
          <svg width="10" height="10" viewBox="0 0 10 10" fill="none">
            <path d="M2 8 L8 2 M8 2 H4 M8 2 V6" stroke="currentColor" stroke-width="1.2" />
          </svg>
        </a>
      ))}
    </div>

    <nav class="mt-4 flex flex-wrap justify-center gap-x-6 gap-y-3 text-[11px] uppercase tracking-[var(--tracking-cap)] text-[var(--color-light-grey)]">
      {copy.nav.map((n) => (
        <a href={n.href} class="transition-colors hover:text-[var(--color-neon-blue)]">{n.label}</a>
      ))}
    </nav>

    <p class="mt-6 text-center text-[11px] uppercase tracking-[var(--tracking-cap)] text-[var(--color-fog)]">
      {copy.copyright}
    </p>
  </div>
</footer>
