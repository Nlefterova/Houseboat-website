---
interface Props {
  lang?: "ru" | "en";
}
const { lang = "ru" } = Astro.props;

// Body copy is authored as HTML so we can highlight brand/product names
// inline in neon-blue (the "magazine" treatment — same prose, visually rhythmic).
const copy = lang === "ru"
  ? {
      eyebrow: "Дополнительные опции",
      title: "Под вас. От тика до встроенной техники.",
      body1Html:
        'Каждое судно собирается под заказ. Мебель из <em>массива дуба</em>, декоративные вставки из <em>композитного алюминия</em>, <em>морской винил</em>, <em>бронзовые</em> акценты.',
      body2Html:
        'Опционально: <em>тик</em> в кокпите, на лестнице и в носовой части — натуральный, <em>Flexiteek</em> (Великобритания) или <em>Flexdeck</em> (Россия). Мебель на флайбридже и в кокпите, тент с москитными сетками. Съёмный <em>тандыр</em> в кормовой зоне, садок для живой рыбы с аэратором, <em>аудиосистема 5.1</em>. Второй пост управления на флайбридже, джойстик <em>Mercury JPO</em> для управления двигателями, автопилот <em>Simrad AP44</em>. Стиральная и сушильная машина, телевизоры в каждой каюте. Материалы, которые становятся только красивее со временем. Полный список — по запросу.',
      ctaLabel: "Обсудить комплектацию",
    }
  : {
      eyebrow: "Optional Equipment",
      title: "Built around you. From teak to integrated tech.",
      body1Html:
        'Each vessel is built to order. <em>Solid-oak</em> furniture, <em>composite aluminum</em> inserts, <em>marine vinyl</em>, <em>bronze</em> accents.',
      body2Html:
        'Optional: <em>teak</em> in the cockpit, on the staircase, and at the bow — natural, <em>Flexiteek</em> (UK) or <em>Flexdeck</em> (Russia). Furniture on the flybridge and in the cockpit. Tent with mosquito screens. Removable <em>tandoor</em> at the stern, live-fish well with aerator, <em>5.1 audio system</em>. Secondary helm on the flybridge, <em>Mercury JPO</em> joystick for engine control, <em>Simrad AP44</em> autopilot. Washer + dryer, TVs in every cabin. Materials that only become more beautiful with time. Full list on request.',
      ctaLabel: "Discuss the build",
    };

// Small carousel slides — option categories with placeholder gradient tints
// matching the photo placeholder pattern used elsewhere.
const slides = lang === "ru"
  ? [
      { name: "Кормовая палуба", note: "Тик · Модульная мебель · Москитные сетки", photo: "options/mosquito-nets.jpg", tint: "linear-gradient(135deg, #2a3640 0%, #131a21 60%, #06090b 100%)" },
      { name: "Декор и мебель", note: "Дуб · Бронза · Композит", photo: "options/decor-lounge.jpg", tint: "linear-gradient(135deg, #3a3320 0%, #1d1813 60%, #0a0805 100%)" },
      { name: "Лестница", note: "Тик · Нержавеющая сталь", photo: "options/staircase-teak.jpg", tint: "linear-gradient(135deg, #20303a 0%, #131a21 60%, #06090b 100%)" },
      { name: "Развлечения", note: "8× TV · Аудио · Wi-Fi", photo: "options/bedroom-tv.jpg", tint: "linear-gradient(135deg, #2a2a2a 0%, #161616 60%, #060606 100%)" },
    ]
  : [
      { name: "Aft Deck", note: "Teak · Modular furniture · Mosquito screens", photo: "options/mosquito-nets.jpg", tint: "linear-gradient(135deg, #2a3640 0%, #131a21 60%, #06090b 100%)" },
      { name: "Decor & Furniture", note: "Oak · Bronze · Composite", photo: "options/decor-lounge.jpg", tint: "linear-gradient(135deg, #3a3320 0%, #1d1813 60%, #0a0805 100%)" },
      { name: "Staircase", note: "Teak · Stainless steel", photo: "options/staircase-teak.jpg", tint: "linear-gradient(135deg, #20303a 0%, #131a21 60%, #06090b 100%)" },
      { name: "Entertainment", note: "8× TV · Audio · Wi-Fi", photo: "options/bedroom-tv.jpg", tint: "linear-gradient(135deg, #2a2a2a 0%, #161616 60%, #060606 100%)" },
    ];

const total = slides.length;
---

<section id="options" class="bg-[var(--color-paper)] py-16 sm:py-24">
  <div class="mx-auto max-w-[1440px] px-8">
    <div class="grid grid-cols-12 gap-x-10 gap-y-12">
      <!-- LEFT: text -->
      <div class="col-span-12 lg:col-span-5">
        <p class="eyebrow">{copy.eyebrow}</p>
        <hr class="rule-ink mt-4" />

        <h2
          class="display mt-8 text-[36px] leading-[1.05] text-[var(--color-ink)] sm:text-[48px]"
        >
          {copy.title}
        </h2>

        <p class="options-body mt-8 text-[16px] leading-[1.7] text-[var(--color-deep-grey)]" set:html={copy.body1Html}></p>
        <p class="options-body mt-4 text-[16px] leading-[1.7] text-[var(--color-deep-grey)]" set:html={copy.body2Html}></p>

        <div class="mt-12">
          <a
            href="#inquire"
            class="btn-secondary group inline-flex items-center gap-3 rounded-full px-7 py-3.5 text-[12px] uppercase tracking-[var(--tracking-cap)]"
          >
            <span>{copy.ctaLabel}</span>
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" class="transition-transform group-hover:translate-x-0.5">
              <path d="M2 10 L10 2 M10 2 H4 M10 2 V8" stroke="currentColor" stroke-width="1.4" />
            </svg>
          </a>
        </div>
      </div>

      <!-- RIGHT: small carousel — same aspect-video size as the Overview video card -->
      <div class="col-span-12 lg:col-span-7">
        <div data-options-carousel data-total={total}>
          <!-- Photo card -->
          <div
            class="relative aspect-video w-full overflow-hidden rounded-[4px] bg-[var(--color-ink)]"
          >
            {slides.map((s, i) => (
              <div
                data-slide-index={i}
                data-slide-name={s.name}
                data-slide-note={s.note}
                class={`absolute inset-0 bg-cover bg-center transition-opacity duration-500 ${i === 0 ? "opacity-100" : "opacity-0"}`}
                style={
                  s.photo
                    ? `background-image: url('${s.photo}');`
                    : `background: ${s.tint};`
                }
                aria-hidden={i !== 0}
              ></div>
            ))}

            <!-- Bottom gradient for caption legibility -->
            <div
              class="pointer-events-none absolute inset-x-0 bottom-0 h-1/2"
              style="background: linear-gradient(180deg, rgba(0,0,0,0) 0%, rgba(0,0,0,0.7) 100%);"
            ></div>

            <!-- Top-right counter -->
            <div class="absolute right-5 top-5 flex items-baseline gap-1 text-[var(--color-paper)]">
              <span data-current-index class="text-[14px] font-light tabular-nums">01</span>
              <span class="text-[10px] uppercase tracking-[var(--tracking-cap)] text-[color-mix(in_srgb,white_55%,transparent)]">
                / {String(total).padStart(2, "0")}
              </span>
            </div>

            <!-- Chevrons -->
            <button
              type="button"
              data-prev
              aria-label="Previous"
              class="absolute left-3 top-1/2 z-10 flex h-10 w-10 -translate-y-1/2 items-center justify-center rounded-[2px] bg-[color-mix(in_srgb,black_55%,transparent)] text-[var(--color-paper)] backdrop-blur-md transition-colors hover:bg-[var(--color-paper)] hover:text-[var(--color-ink)]"
            >
              <svg width="16" height="16" viewBox="0 0 20 20" fill="none">
                <path d="M12 4 L6 10 L12 16" stroke="currentColor" stroke-width="1.6" stroke-linecap="square" />
              </svg>
            </button>
            <button
              type="button"
              data-next
              aria-label="Next"
              class="absolute right-3 top-1/2 z-10 flex h-10 w-10 -translate-y-1/2 items-center justify-center rounded-[2px] bg-[color-mix(in_srgb,black_55%,transparent)] text-[var(--color-paper)] backdrop-blur-md transition-colors hover:bg-[var(--color-paper)] hover:text-[var(--color-ink)]"
            >
              <svg width="16" height="16" viewBox="0 0 20 20" fill="none">
                <path d="M8 4 L14 10 L8 16" stroke="currentColor" stroke-width="1.6" stroke-linecap="square" />
              </svg>
            </button>

            <!-- Slide caption overlaid bottom-left -->
            <div class="absolute inset-x-5 bottom-5 sm:inset-x-7 sm:bottom-7">
              <p
                data-caption-note
                class="text-[10px] uppercase tracking-[var(--tracking-wide-cap)] text-[color-mix(in_srgb,white_70%,transparent)]"
              >
                {slides[0].note}
              </p>
              <h3
                data-caption-name
                class="display mt-2 text-[22px] leading-[1.05] text-[var(--color-paper)] sm:text-[28px]"
              >
                {slides[0].name}
              </h3>
            </div>
          </div>

          <!-- Progress segments -->
          <div class="mt-3 flex gap-1.5">
            {slides.map((_, i) => (
              <button
                type="button"
                data-dot-index={i}
                aria-label={`Slide ${i + 1}`}
                class={`h-[2px] flex-1 transition-colors ${i === 0 ? "bg-[var(--color-neon-blue)]" : "bg-[var(--color-grey)] hover:bg-[var(--color-fog)]"}`}
              ></button>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLElement>("[data-options-carousel]").forEach((root) => {
    const total = Number(root.dataset.total ?? 0);
    if (!total) return;
    const slides = root.querySelectorAll<HTMLElement>("[data-slide-index]");
    const dots = root.querySelectorAll<HTMLElement>("[data-dot-index]");
    const counter = root.querySelector<HTMLElement>("[data-current-index]");
    const captionName = root.querySelector<HTMLElement>("[data-caption-name]");
    const captionNote = root.querySelector<HTMLElement>("[data-caption-note]");
    const prev = root.querySelector<HTMLElement>("[data-prev]");
    const next = root.querySelector<HTMLElement>("[data-next]");
    let i = 0;

    function go(n: number) {
      i = ((n % total) + total) % total;
      slides.forEach((el, idx) => {
        el.style.opacity = idx === i ? "1" : "0";
        el.setAttribute("aria-hidden", idx === i ? "false" : "true");
      });
      dots.forEach((el, idx) => {
        if (idx === i) {
          el.classList.remove("bg-[var(--color-grey)]", "hover:bg-[var(--color-fog)]");
          el.classList.add("bg-[var(--color-neon-blue)]");
        } else {
          el.classList.remove("bg-[var(--color-neon-blue)]");
          el.classList.add("bg-[var(--color-grey)]", "hover:bg-[var(--color-fog)]");
        }
      });
      if (counter) counter.textContent = String(i + 1).padStart(2, "0");
      const activeSlide = slides[i] as HTMLElement | undefined;
      if (activeSlide) {
        if (captionName) captionName.textContent = activeSlide.dataset.slideName ?? "";
        if (captionNote) captionNote.textContent = activeSlide.dataset.slideNote ?? "";
      }
    }

    prev?.addEventListener("click", () => go(i - 1));
    next?.addEventListener("click", () => go(i + 1));
    dots.forEach((dot, idx) => dot.addEventListener("click", () => go(idx)));
  });
</script>

<style>
  /* Brand/product names inside body copy — magazine-style highlight,
     not italic. Keeps prose intact, lets the eye latch onto signatures. */
  .options-body :global(em) {
    font-style: normal;
    color: var(--color-neon-blue);
    font-weight: 500;
  }
  /* Two-column body2: avoid orphan/widow breaks in the middle of a highlighted span. */
  .options-body :global(em) {
    break-inside: avoid;
  }
</style>
