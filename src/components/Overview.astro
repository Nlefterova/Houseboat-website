---
interface Props {
  lang?: "ru" | "en";
}
const { lang = "ru" } = Astro.props;

const copy = lang === "ru"
  ? {
      eyebrow: "Обзор",
      title: "Гражданская версия экспедиционного судна.",
      body1:
        "Корпус из нержавеющей стали 12х18н10т. Надстройка из авиационного алюминия АМг5М. Зимний пакет до −30 °C. Технологии выживания, не косметика.",
      body2:
        "5 кают, 2 камбуза, сауна, два подвесных мотора 250–350 л.с. Дом, который идёт за впечатлением — туда, где обычная лодка не пройдёт.",
      ctaLabel: "Посмотреть спецификацию",
      features: [
        { label: "Дуб и тик", icon: "wood" },
        { label: "Банный комплекс", icon: "steam" },
        { label: "Нержавеющая сталь", icon: "shield" },
      ],
      videoChip: "Видео",
      videoInvite: "Поднимитесь на борт.",
      videoSub: "Прогулка по судну · 1:30",
    }
  : {
      eyebrow: "Overview",
      title: "The civilian version of an expedition vessel.",
      body1:
        "Stainless-steel hull. Aviation-grade aluminum AlMg5 superstructure. Winter package down to −30 °C. Survival-grade technology, not cosmetic.",
      body2:
        "5 cabins, 2 galleys, sauna, twin outboards 250–350 hp. A home that follows experience — where ordinary boats can't go.",
      ctaLabel: "View Full Specification",
      features: [
        { label: "Oak & Teak", icon: "wood" },
        { label: "Banya Complex", icon: "steam" },
        { label: "Stainless Steel", icon: "shield" },
      ],
      videoChip: "Video",
      videoInvite: "Step aboard.",
      videoSub: "A walk through the vessel · 1:30",
    };
---

<section id="overview" class="bg-[var(--color-paper)] py-16 sm:py-24">
  <div class="mx-auto max-w-[1440px] px-8">
    <div class="grid grid-cols-12 gap-x-10 gap-y-12">
      <!-- TEXT side -->
      <div class="col-span-12 lg:col-span-5">
        <p class="eyebrow lg:-mt-8">{copy.eyebrow}</p>
        <hr class="rule-ink mt-4" />

        <h2
          class="display mt-8 text-[36px] leading-[1.05] text-[var(--color-ink)] sm:text-[48px]"
        >
          {copy.title}
        </h2>

        <p class="mt-5 text-[16px] leading-[1.7] text-[var(--color-deep-grey)]">{copy.body1}</p>
        <p class="mt-4 text-[16px] leading-[1.7] text-[var(--color-deep-grey)]">{copy.body2}</p>

        <ul class="mt-8 grid grid-cols-3 gap-4 sm:gap-8">
          {copy.features.map((f) => (
            <li class="border-l-2 border-[var(--color-neon-blue)] pl-4">
              <span class="block text-[var(--color-neon-blue)]">
                {f.icon === "wood" && (
                  <svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
                    <path d="M11 2 L11 20 M11 6 L7 9 M11 6 L15 9 M11 11 L7 14 M11 11 L15 14 M11 16 L8 18 M11 16 L14 18" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />
                  </svg>
                )}
                {f.icon === "steam" && (
                  <svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
                    <path d="M4 14 Q7 11, 10 14 T 16 14 T 22 14" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" fill="none" />
                    <path d="M2 10 Q5 7, 8 10 T 14 10 T 20 10" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" fill="none" />
                    <path d="M4 6 Q7 3, 10 6 T 16 6" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" fill="none" />
                  </svg>
                )}
                {f.icon === "shield" && (
                  <svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
                    <path d="M11 2 L18 5 L18 11 Q18 16, 11 20 Q4 16, 4 11 L4 5 Z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round" fill="none" />
                    <path d="M8 10 L10.5 12.5 L14.5 8.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" fill="none" />
                  </svg>
                )}
              </span>
              <p class="mt-3 text-[11px] font-semibold uppercase leading-[1.3] tracking-[var(--tracking-cap)] text-[var(--color-ink)] sm:text-[12px]">
                {f.label}
              </p>
            </li>
          ))}
        </ul>

        <div class="mt-10">
          <a
            href="#spec"
            class="btn-secondary group inline-flex items-center gap-3 rounded-full px-7 py-3.5 text-[12px] uppercase tracking-[var(--tracking-cap)]"
          >
            <span>{copy.ctaLabel}</span>
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" class="transition-transform group-hover:translate-x-0.5">
              <path d="M2 10 L10 2 M10 2 H4 M10 2 V8" stroke="currentColor" stroke-width="1.4" />
            </svg>
          </a>
        </div>
      </div>

      <!-- VIDEO side -->
      <div class="col-span-12 lg:col-span-7">
        <div
          id="overview-video-card"
          class="group relative block aspect-[7/4] w-full overflow-hidden rounded-[4px] bg-[var(--color-ink)] text-left"
        >
          <!-- The actual video — shows poster until play -->
          <video
            id="overview-video"
            class="absolute inset-0 h-full w-full object-cover"
            poster="video/poster.jpg"
            preload="metadata"
            playsinline
          >
            <source src="video/walkthrough.mp4" type="video/mp4" />
          </video>

          <!-- Overlay layer: chip + invitation + play button. Hidden when video plays. -->
          <button
            id="overview-video-trigger"
            type="button"
            aria-label={copy.videoInvite}
            class="absolute inset-0 z-10 cursor-pointer text-left transition-opacity duration-500 data-[playing]:pointer-events-none data-[playing]:opacity-0"
          >
            <div
              class="absolute inset-0"
              style="background: linear-gradient(180deg, rgba(0,0,0,0.25) 0%, rgba(0,0,0,0.05) 40%, rgba(0,0,0,0.7) 100%);"
            ></div>

            <span
              class="absolute left-6 top-6 inline-flex items-center gap-2 rounded-[2px] border border-[color-mix(in_srgb,white_45%,transparent)] bg-[color-mix(in_srgb,black_30%,transparent)] px-3 py-1.5 text-[11px] uppercase tracking-[var(--tracking-cap)] text-[var(--color-paper)] backdrop-blur-md"
            >
              <span class="h-1.5 w-1.5 rounded-full bg-[var(--color-paper)]"></span>
              {copy.videoChip}
            </span>

            <span
              class="pointer-events-none absolute inset-0 m-auto flex h-20 w-20 items-center justify-center rounded-full border border-[color-mix(in_srgb,white_60%,transparent)] bg-[color-mix(in_srgb,black_40%,transparent)] text-[var(--color-paper)] backdrop-blur-md transition-all duration-300 group-hover:scale-110 group-hover:border-[var(--color-paper)] group-hover:bg-[var(--color-paper)] group-hover:text-[var(--color-ink)]"
            >
              <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
                <path d="M8 5 L20 12 L8 19 Z" />
              </svg>
            </span>

            <div class="absolute inset-x-6 bottom-6 sm:inset-x-10 sm:bottom-10">
              <p
                class="display text-[32px] leading-[1.05] text-[var(--color-paper)] sm:text-[44px] md:text-[52px]"
              >
                {copy.videoInvite}
              </p>
              <p
                class="mt-3 text-[11px] uppercase tracking-[var(--tracking-cap)] text-[color-mix(in_srgb,white_70%,transparent)]"
              >
                {copy.videoSub}
              </p>
            </div>
          </button>
        </div>

        <script>
          const trigger = document.getElementById("overview-video-trigger");
          const video = document.getElementById("overview-video") as HTMLVideoElement | null;
          if (trigger && video) {
            const showOverlay = () => {
              video.controls = false;
              trigger.removeAttribute("data-playing");
            };
            trigger.addEventListener("click", () => {
              video.controls = true;
              video.play();
              trigger.setAttribute("data-playing", "");
            });
            // On pause / end → restore the initial overlay look (no native controls,
            // video stays at current playback time so resume continues from there).
            video.addEventListener("pause", showOverlay);
            video.addEventListener("ended", showOverlay);
          }
        </script>
      </div>
    </div>
  </div>
</section>
