---
interface Props {
  lang?: "ru" | "en";
}
const { lang = "ru" } = Astro.props;

const copy = lang === "ru"
  ? {
      chip: "На карте",
      title: "Наши Локации",
      lede:
        "Три точки присутствия KARTEL: от офиса продаж в Москве до исторической верфи на Волге.",
      mapEyebrow: "Наши локации на карте",
      mapHint: "Выберите локацию для просмотра на карте",
      mapCtaLabel: "Открыть на Яндекс.Картах",
    }
  : {
      chip: "Bases",
      title: "Our Locations",
      lede:
        "Three points of KARTEL presence: from the Moscow sales office to the historic shipyard on the Volga.",
      mapEyebrow: "Our locations on the map",
      mapHint: "Select a location to view on the map",
      mapCtaLabel: "Open in Yandex Maps",
    };

type Location = {
  icon: "office" | "anchor" | "factory";
  eyebrow: string;
  title: string;
  lines: string[];
  phone?: string;
  note?: string;
  cta?: { label: string; href: string };
  mapHref: string;
};

const locations: Location[] = lang === "ru"
  ? [
      {
        icon: "office",
        eyebrow: "Штаб-квартира",
        title: "Москва, ЦМТ",
        lines: [
          "Краснопресненская наб., 12",
          "6-й подъезд, 11 этаж, офис 1148",
          "Гостиница «Международная»",
        ],
        phone: "+7 (495) 741-82-58",
        note: "Репрезентативный офис в центре",
        mapHref: "https://yandex.ru/maps/?text=Краснопресненская+наб.+12+Москва",
      },
      {
        icon: "anchor",
        eyebrow: "Шоурум на воде",
        title: "Саратов, Splaffreid",
        lines: [
          "ул. Большая Затонская",
          "(район Затона)",
          "51.544010, 46.081743",
        ],
        note: "Тест-драйв в реальных условиях",
        mapHref: "https://yandex.ru/maps/?ll=46.081743,51.544010&z=17&pt=46.081743,51.544010",
      },
      {
        icon: "factory",
        eyebrow: "Производство",
        title: "Корабельная Артель",
        lines: [
          "г. Саратов",
          "Производственная база",
          "Историческая верфь с 1992 года",
        ],
        cta: { label: "История верфи", href: "#heritage" },
        mapHref: "https://yandex.ru/maps/?text=Саратов+верфь",
      },
    ]
  : [
      {
        icon: "office",
        eyebrow: "Headquarters",
        title: "Moscow, WTC",
        lines: [
          "Krasnopresnenskaya emb., 12",
          "Entrance 6, floor 11, office 1148",
          "Mezhdunarodnaya Hotel",
        ],
        phone: "+7 (495) 741-82-58",
        note: "Representative office in central Moscow",
        mapHref: "https://yandex.com/maps/?text=Krasnopresnenskaya+12+Moscow",
      },
      {
        icon: "anchor",
        eyebrow: "Showroom on Water",
        title: "Saratov, Splaffreid",
        lines: [
          "Bolshaya Zatonskaya St.",
          "(Zaton district)",
          "51.544010, 46.081743",
        ],
        note: "Sea trial in real conditions",
        mapHref: "https://yandex.com/maps/?ll=46.081743,51.544010&z=17&pt=46.081743,51.544010",
      },
      {
        icon: "factory",
        eyebrow: "Production",
        title: "Shipbuilders' Artel",
        lines: [
          "Saratov",
          "Production facility",
          "Historic shipyard since 1992",
        ],
        cta: { label: "Shipyard story", href: "#heritage" },
        mapHref: "https://yandex.com/maps/?text=Saratov+shipyard",
      },
    ];
---

<section id="locations" class="bg-[var(--color-paper)] py-16 sm:py-24">
  <div class="mx-auto max-w-[1440px] px-8">
    <!-- Header -->
    <div class="text-center">
      <span
        class="inline-flex items-center gap-2 rounded-[2px] border border-[var(--color-neon-blue)] px-3 py-1.5 text-[10px] uppercase tracking-[var(--tracking-cap)] text-[var(--color-neon-blue)]"
      >
        <span class="h-1.5 w-1.5 rounded-full bg-[var(--color-neon-blue)]"></span>
        {copy.chip}
      </span>
      <h2
        class="display mt-6 text-[36px] leading-[1.05] text-[var(--color-ink)] sm:text-[48px]"
      >
        {copy.title}
      </h2>
      <p
        class="mx-auto mt-5 max-w-2xl text-[15px] leading-[1.65] text-[var(--color-deep-grey)] sm:text-[16px]"
      >
        {copy.lede}
      </p>
    </div>

    <!-- 3 location cards — clean cards with blue top accent -->
    <div class="mt-12 grid grid-cols-1 gap-4 md:grid-cols-3 md:gap-6">
      {locations.map((loc) => (
        <article
          class="relative flex h-full flex-col border border-[var(--color-grey)] bg-[var(--color-paper)] p-8 sm:p-10"
        >
          <!-- Top accent strip — brand blue, signals "this is one of three" -->
          <span class="absolute inset-x-0 top-0 h-[3px] bg-[var(--color-neon-blue)]"></span>

          <!-- Icon -->
          <div class="text-[var(--color-neon-blue)]">
            {loc.icon === "office" && (
              <svg width="24" height="24" viewBox="0 0 18 18" fill="none">
                <rect x="3" y="2" width="12" height="14" stroke="currentColor" stroke-width="1.2" />
                <line x1="6" y1="6" x2="8" y2="6" stroke="currentColor" stroke-width="1.2" />
                <line x1="10" y1="6" x2="12" y2="6" stroke="currentColor" stroke-width="1.2" />
                <line x1="6" y1="9" x2="8" y2="9" stroke="currentColor" stroke-width="1.2" />
                <line x1="10" y1="9" x2="12" y2="9" stroke="currentColor" stroke-width="1.2" />
                <line x1="6" y1="12" x2="8" y2="12" stroke="currentColor" stroke-width="1.2" />
                <line x1="10" y1="12" x2="12" y2="12" stroke="currentColor" stroke-width="1.2" />
              </svg>
            )}
            {loc.icon === "anchor" && (
              <svg width="24" height="24" viewBox="0 0 18 18" fill="none">
                <circle cx="9" cy="4" r="1.5" stroke="currentColor" stroke-width="1.2" />
                <line x1="9" y1="5.5" x2="9" y2="14" stroke="currentColor" stroke-width="1.2" />
                <line x1="6.5" y1="7.5" x2="11.5" y2="7.5" stroke="currentColor" stroke-width="1.2" />
                <path d="M3 11 Q3 14, 9 14 Q15 14, 15 11" stroke="currentColor" stroke-width="1.2" fill="none" />
              </svg>
            )}
            {loc.icon === "factory" && (
              <svg width="24" height="24" viewBox="0 0 18 18" fill="none">
                <path d="M3 15 V8 L7 10 V8 L11 10 V8 L15 10 V15 H3 Z" stroke="currentColor" stroke-width="1.2" fill="none" />
                <rect x="6" y="12" width="2" height="3" fill="currentColor" />
                <rect x="10" y="12" width="2" height="3" fill="currentColor" />
              </svg>
            )}
          </div>

          <!-- Eyebrow -->
          <p class="mt-8 text-[10px] uppercase tracking-[var(--tracking-wide-cap)] text-[var(--color-fog)]">
            {loc.eyebrow}
          </p>

          <!-- Title -->
          <h3 class="display mt-3 text-[24px] leading-[1.05] uppercase text-[var(--color-ink)] sm:text-[28px]">
            {loc.title}
          </h3>

          <!-- Address lines -->
          <div class="mt-6 space-y-1 text-[14px] leading-[1.55] text-[var(--color-deep-grey)]">
            {loc.lines.map((line) => (
              <p>{line}</p>
            ))}
          </div>

          <!-- Phone / Note / CTA -->
          {loc.phone && (
            <a
              href={`tel:${loc.phone.replace(/[^+\d]/g, "")}`}
              class="mt-6 inline-block text-[15px] font-medium text-[var(--color-ink)] transition-colors hover:text-[var(--color-neon-blue)]"
            >
              {loc.phone}
            </a>
          )}
          {loc.note && (
            <p class="mt-6 text-[14px] italic leading-[1.55] text-[var(--color-deep-grey)]">
              {loc.note}
            </p>
          )}
          {loc.cta && (
            <a
              href={loc.cta.href}
              class="mt-6 inline-flex items-center gap-2 text-[11px] uppercase tracking-[var(--tracking-cap)] text-[var(--color-ink)] transition-colors hover:text-[var(--color-neon-blue)]"
            >
              <span>{loc.cta.label}</span>
              <svg width="10" height="10" viewBox="0 0 10 10" fill="none">
                <path d="M2 8 L8 2 M8 2 H4 M8 2 V6" stroke="currentColor" stroke-width="1.2" />
              </svg>
            </a>
          )}

          <!-- Map link at bottom -->
          <div class="mt-auto pt-8">
            <a
              href={loc.mapHref}
              target="_blank"
              rel="noopener"
              class="group inline-flex items-center gap-2 text-[10px] uppercase tracking-[var(--tracking-wide-cap)] text-[var(--color-fog)] transition-colors hover:text-[var(--color-neon-blue)]"
            >
              <svg width="11" height="11" viewBox="0 0 12 12" fill="none">
                <path d="M6 1 C 8.5 1 10 2.5 10 5 C 10 8 6 11 6 11 C 6 11 2 8 2 5 C 2 2.5 3.5 1 6 1 Z" stroke="currentColor" stroke-width="1" />
                <circle cx="6" cy="5" r="1.5" stroke="currentColor" stroke-width="1" />
              </svg>
              <span>{copy.mapCtaLabel}</span>
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
