---
interface Props {
  lang?: "ru" | "en";
}
const { lang = "ru" } = Astro.props;

const copy = lang === "ru"
  ? {
      eyebrow: "Связаться с KARTEL",
      title: "Оставьте контакты — мы свяжемся и обсудим ваш проект.",
      lede: "Быстро. По делу. Без спама.",
      labels: {
        name: "Имя",
        phone: "Телефон",
        email: "Email",
        city: "Город",
        method: "Способ связи",
      },
      placeholders: {
        name: "Ваше имя",
        phone: "+7",
        email: "name@example.com",
        cityDefault: "Выберите город",
      },
      cities: [
        "Москва",
        "Санкт-Петербург",
        "Саратов",
        "Казань",
        "Нижний Новгород",
        "Екатеринбург",
        "Новосибирск",
        "Краснодар",
        "Сочи",
        "Владивосток",
        "Другой город",
      ],
      methods: ["Звонок", "WhatsApp", "Telegram", "Email"],
      submit: "Отправить запрос",
      legal:
        "Нажимая кнопку, вы соглашаетесь на обратную связь от KARTEL Boats.",
      // Footer
      footerCtaEyebrow: "Начните свой маршрут",
      footerCtaSub: "Тест-драйв и осмотр корпуса по записи",
      footerCtaLabel: "Записаться на тест-драйв",
      colLocations: "Локации",
      colContacts: "Контакты",
      locations: [
        {
          name: "Москва · Офис",
          lines: [
            "Краснопресненская наб. 12",
            "6-й подъезд, 11 этаж, офис 1148",
            "Гостиница «Международная»",
          ],
        },
        { name: "Верфь · Саратов", lines: ["г. Саратов, ул. Огородная, 3"] },
        { name: "Шоурум · Саратов", lines: ["г. Саратов, ул. Большая Затонская"] },
      ],
      phoneFooter: "+7 (495) 741-82-58",
      emailFooter: "office@kartelboats.ru",
      relatedLabel: "Связанные сайты",
      related: [
        { label: "Kartel Boats", href: "https://kartelboats.ru" },
        { label: "Корабельная Артель (верфь)", href: "https://kartelboats.ru" },
      ],
      nav: [
        { label: "Главная", href: "/" },
        { label: "Интерьер", href: "#interior" },
        { label: "Спецификация", href: "#spec" },
        { label: "Наследие", href: "#heritage" },
        { label: "Локации", href: "#locations" },
        { label: "Заявка", href: "#inquire" },
      ],
      copyright: "© 2026 KARTEL Boats",
    }
  : {
      eyebrow: "Contact KARTEL",
      title: "Leave your details — we'll get in touch about your project.",
      lede: "Direct. To the point. No spam.",
      labels: {
        name: "Name",
        phone: "Phone",
        email: "Email",
        city: "City",
        method: "Preferred contact",
      },
      placeholders: {
        name: "Your name",
        phone: "+1",
        email: "name@example.com",
        cityDefault: "Select city",
      },
      cities: [
        "Moscow",
        "Saint Petersburg",
        "Saratov",
        "Kazan",
        "Nizhny Novgorod",
        "Yekaterinburg",
        "Novosibirsk",
        "Krasnodar",
        "Sochi",
        "Vladivostok",
        "Other",
      ],
      methods: ["Call", "WhatsApp", "Telegram", "Email"],
      submit: "Send Request",
      legal: "By submitting, you agree to be contacted by KARTEL Boats.",
      footerCtaEyebrow: "Start your route",
      footerCtaSub: "Sea trial and hull inspection by appointment",
      footerCtaLabel: "Book a sea trial",
      colLocations: "Locations",
      colContacts: "Contacts",
      locations: [
        {
          name: "Moscow · Office",
          lines: [
            "Krasnopresnenskaya emb. 12",
            "Entrance 6, floor 11, office 1148",
            "Mezhdunarodnaya Hotel",
          ],
        },
        { name: "Shipyard · Saratov", lines: ["Saratov, Ogorodnaya St. 3"] },
        { name: "Showroom · Saratov", lines: ["Saratov, Bolshaya Zatonskaya St."] },
      ],
      phoneFooter: "+7 (495) 741-82-58",
      emailFooter: "office@kartelboats.ru",
      relatedLabel: "Related sites",
      related: [
        { label: "Kartel Boats", href: "https://kartelboats.ru" },
        { label: "Shipbuilders' Artel (shipyard)", href: "https://kartelboats.ru" },
      ],
      nav: [
        { label: "Home", href: "/" },
        { label: "Interior", href: "#interior" },
        { label: "Specs", href: "#spec" },
        { label: "Heritage", href: "#heritage" },
        { label: "Locations", href: "#locations" },
        { label: "Inquire", href: "#inquire" },
      ],
      copyright: "© 2026 KARTEL Boats",
    };
---

<section id="inquire" class="bg-[var(--color-ink)] text-[var(--color-paper)]">
  <div class="mx-auto max-w-[1440px] px-8 pt-28 pb-28 sm:pt-36 sm:pb-36">
    <!-- ───── FORM AREA ───── -->
    <div class="grid grid-cols-12 gap-x-8 gap-y-12">
      <!-- LEFT: copy -->
      <div class="col-span-12 lg:col-span-5">
        <p class="text-[11px] uppercase tracking-[var(--tracking-wide-cap)] text-[var(--color-grey)]">
          {copy.eyebrow}
        </p>
        <hr class="mt-4 h-px w-14 border-0 bg-[var(--color-paper)]" />
        <h2 class="display mt-8 text-[36px] leading-[1.1] text-[var(--color-paper)] sm:text-[52px]">
          {copy.title}
        </h2>
        <p class="mt-6 text-[16px] leading-[1.6] text-[var(--color-light-grey)]">{copy.lede}</p>
      </div>

      <!-- RIGHT: form -->
      <form class="col-span-12 lg:col-span-7" autocomplete="on" novalidate>
        <div class="grid grid-cols-1 gap-x-8 gap-y-7 sm:grid-cols-2">
          <label class="block">
            <span class="text-[10px] uppercase tracking-[var(--tracking-wide-cap)] text-[var(--color-grey)]">
              {copy.labels.name} *
            </span>
            <input
              type="text"
              name="name"
              required
              placeholder={copy.placeholders.name}
              class="mt-2 w-full border-0 border-b border-[color-mix(in_srgb,var(--color-paper)_30%,transparent)] bg-transparent pb-2.5 text-[16px] text-[var(--color-paper)] placeholder:text-[var(--color-fog)] focus:border-[var(--color-paper)] focus:outline-none"
            />
          </label>
          <label class="block">
            <span class="text-[10px] uppercase tracking-[var(--tracking-wide-cap)] text-[var(--color-grey)]">
              {copy.labels.phone} *
            </span>
            <input
              type="tel"
              name="phone"
              required
              placeholder={copy.placeholders.phone}
              class="mt-2 w-full border-0 border-b border-[color-mix(in_srgb,var(--color-paper)_30%,transparent)] bg-transparent pb-2.5 text-[16px] text-[var(--color-paper)] placeholder:text-[var(--color-fog)] focus:border-[var(--color-paper)] focus:outline-none"
            />
          </label>
          <label class="block">
            <span class="text-[10px] uppercase tracking-[var(--tracking-wide-cap)] text-[var(--color-grey)]">
              {copy.labels.email} *
            </span>
            <input
              type="email"
              name="email"
              required
              placeholder={copy.placeholders.email}
              class="mt-2 w-full border-0 border-b border-[color-mix(in_srgb,var(--color-paper)_30%,transparent)] bg-transparent pb-2.5 text-[16px] text-[var(--color-paper)] placeholder:text-[var(--color-fog)] focus:border-[var(--color-paper)] focus:outline-none"
            />
          </label>
          <label class="block">
            <span class="text-[10px] uppercase tracking-[var(--tracking-wide-cap)] text-[var(--color-grey)]">
              {copy.labels.city} *
            </span>
            <select
              name="city"
              required
              class="mt-2 w-full appearance-none border-0 border-b border-[color-mix(in_srgb,var(--color-paper)_30%,transparent)] bg-transparent pb-2.5 pr-6 text-[16px] text-[var(--color-paper)] focus:border-[var(--color-paper)] focus:outline-none"
              style="background-image: url('data:image/svg+xml;utf8,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2210%22 height=%226%22 viewBox=%220 0 10 6%22 fill=%22none%22><path d=%22M1 1 L5 5 L9 1%22 stroke=%22%23ffffff%22 stroke-width=%221%22/></svg>'); background-repeat: no-repeat; background-position: right 0 bottom 12px;"
            >
              <option value="" class="bg-[var(--color-ink)] text-[var(--color-paper)]">
                {copy.placeholders.cityDefault}
              </option>
              {copy.cities.map((c) => (
                <option value={c} class="bg-[var(--color-ink)] text-[var(--color-paper)]">{c}</option>
              ))}
            </select>
          </label>
        </div>

        <fieldset class="mt-10">
          <legend class="text-[10px] uppercase tracking-[var(--tracking-wide-cap)] text-[var(--color-grey)]">
            {copy.labels.method} *
          </legend>
          <div class="mt-4 flex flex-wrap gap-2">
            {copy.methods.map((m, i) => (
              <label class="cursor-pointer">
                <input
                  type="radio"
                  name="contact_method"
                  value={m}
                  required={i === 0}
                  class="peer sr-only"
                  checked={i === 0}
                />
                <span class="inline-flex items-center rounded-full border border-[color-mix(in_srgb,var(--color-paper)_30%,transparent)] px-5 py-2.5 text-[11px] uppercase tracking-[var(--tracking-cap)] text-[var(--color-light-grey)] transition-colors hover:border-[var(--color-paper)] hover:text-[var(--color-paper)] peer-checked:border-[var(--color-paper)] peer-checked:bg-[var(--color-paper)] peer-checked:text-[var(--color-ink)]">
                  {m}
                </span>
              </label>
            ))}
          </div>
        </fieldset>

        <div class="mt-10 flex flex-col items-start gap-5 sm:flex-row sm:items-center sm:justify-between">
          <button
            type="submit"
            class="group inline-flex items-center gap-2 rounded-full bg-[var(--color-paper)] px-7 py-3.5 text-[12px] uppercase tracking-[var(--tracking-cap)] text-[var(--color-ink)] transition-colors hover:bg-[var(--color-light-grey)]"
          >
            <span>{copy.submit}</span>
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" class="transition-transform group-hover:translate-x-0.5">
              <path d="M2 10 L10 2 M10 2 H4 M10 2 V8" stroke="currentColor" stroke-width="1.4" />
            </svg>
          </button>
          <p class="max-w-md text-[11px] leading-[1.55] text-[var(--color-fog)]">{copy.legal}</p>
        </div>
      </form>
    </div>
  </div>

  <!-- ───── FOOTER AREA — full-width slightly lighter dark band ───── -->
  <div class="bg-[var(--color-ink-soft)]">
    <div class="mx-auto max-w-[1440px] px-8 pt-16 sm:pt-20">
      <div class="grid grid-cols-12 gap-x-10 gap-y-14">
      <!-- Col 1: KARTEL + CTA -->
      <div class="col-span-12 lg:col-span-4">
        <span class="text-[24px] font-bold uppercase tracking-[0.12em] text-[var(--color-paper)]">KARTEL</span>
        <h3 class="display mt-8 text-[28px] leading-[1.1] text-[var(--color-paper)] sm:text-[32px]">
          {copy.footerCtaEyebrow}
        </h3>
        <p class="mt-4 max-w-xs text-[14px] leading-[1.55] text-[var(--color-light-grey)]">
          {copy.footerCtaSub}
        </p>
        <a
          href="#inquire"
          class="group mt-6 inline-flex items-center gap-2 rounded-full border border-[color-mix(in_srgb,var(--color-paper)_50%,transparent)] px-6 py-3 text-[11px] uppercase tracking-[var(--tracking-cap)] text-[var(--color-paper)] transition-colors hover:border-[var(--color-paper)] hover:bg-[var(--color-paper)] hover:text-[var(--color-ink)]"
        >
          <span>{copy.footerCtaLabel}</span>
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" class="transition-transform group-hover:translate-x-0.5">
            <path d="M2 10 L10 2 M10 2 H4 M10 2 V8" stroke="currentColor" stroke-width="1.4" />
          </svg>
        </a>
      </div>

      <!-- Col 2: Locations -->
      <div class="col-span-12 sm:col-span-6 lg:col-span-4">
        <p class="text-[11px] uppercase tracking-[var(--tracking-wide-cap)] text-[var(--color-grey)]">
          {copy.colLocations}
        </p>
        <ul class="mt-6 space-y-5">
          {copy.locations.map((l) => (
            <li>
              <div class="flex items-start gap-2">
                <svg width="12" height="13" viewBox="0 0 12 13" fill="none" class="mt-1 flex-none text-[var(--color-paper)]">
                  <path d="M6 1 C 8.5 1 10 2.5 10 5 C 10 8 6 12 6 12 C 6 12 2 8 2 5 C 2 2.5 3.5 1 6 1 Z" stroke="currentColor" stroke-width="1" />
                  <circle cx="6" cy="5" r="1.5" stroke="currentColor" stroke-width="1" />
                </svg>
                <div>
                  <p class="text-[14px] font-medium text-[var(--color-paper)]">{l.name}</p>
                  <div class="mt-1 space-y-0.5 text-[13px] leading-[1.55] text-[var(--color-light-grey)]">
                    {l.lines.map((line) => (<p>{line}</p>))}
                  </div>
                </div>
              </div>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 3: Contacts -->
      <div class="col-span-12 sm:col-span-6 lg:col-span-4">
        <p class="text-[11px] uppercase tracking-[var(--tracking-wide-cap)] text-[var(--color-grey)]">
          {copy.colContacts}
        </p>
        <ul class="mt-6 space-y-4">
          <li>
            <a
              href={`tel:${copy.phoneFooter.replace(/[^+\d]/g, "")}`}
              class="inline-flex items-center gap-3 text-[15px] text-[var(--color-paper)] hover:underline"
            >
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                <path d="M3 3 C 3 3 5 2 6 3 L 7 5 C 7.5 5.5 7 6 6.5 6.5 C 7.5 8.5 8 9 9.5 10 C 10 9.5 10.5 9 11 9.5 L 13 10.5 C 14 11.5 13 13 12 13 C 7 13 1 7 1 2 C 1 1 2.5 0 3 1 Z" stroke="currentColor" stroke-width="1.1" />
              </svg>
              {copy.phoneFooter}
            </a>
          </li>
          <li>
            <a
              href={`mailto:${copy.emailFooter}`}
              class="inline-flex items-center gap-3 text-[15px] text-[var(--color-paper)] hover:underline"
            >
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                <rect x="1" y="3" width="12" height="9" stroke="currentColor" stroke-width="1.1" />
                <path d="M1 4 L7 8 L13 4" stroke="currentColor" stroke-width="1.1" />
              </svg>
              {copy.emailFooter}
            </a>
          </li>
        </ul>

        <div class="mt-8 flex items-center gap-3">
          <a
            href="https://t.me/kartelboats"
            target="_blank"
            rel="noopener"
            aria-label="Telegram"
            class="flex h-9 w-9 items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--color-paper)_30%,transparent)] text-[var(--color-paper)] transition-colors hover:border-[var(--color-paper)] hover:bg-[var(--color-paper)] hover:text-[var(--color-ink)]"
          >
            <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor">
              <path d="M14.5 1.5 L1.5 6.5 L6 7.8 L7.8 13.5 L10 9 L13 11 L14.5 1.5 Z" />
            </svg>
          </a>
          <a
            href="https://www.youtube.com/@kartelboats"
            target="_blank"
            rel="noopener"
            aria-label="YouTube"
            class="flex h-9 w-9 items-center justify-center rounded-full border border-[color-mix(in_srgb,var(--color-paper)_30%,transparent)] text-[var(--color-paper)] transition-colors hover:border-[var(--color-paper)] hover:bg-[var(--color-paper)] hover:text-[var(--color-ink)]"
          >
            <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor">
              <path d="M2 4 L2 12 C 2 13, 3 14, 4 14 L 12 14 C 13 14, 14 13, 14 12 L 14 4 C 14 3, 13 2, 12 2 L 4 2 C 3 2, 2 3, 2 4 Z" />
              <path d="M6.5 5.5 L 11 8 L 6.5 10.5 Z" fill="var(--color-ink)" />
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- ───── BOTTOM STRIP ───── -->
    <hr class="mt-16 h-px border-0 bg-[color-mix(in_srgb,var(--color-paper)_15%,transparent)]" />

    <div class="mt-8 flex flex-wrap items-baseline gap-x-6 gap-y-3 text-[11px] uppercase tracking-[var(--tracking-cap)]">
      <span class="text-[var(--color-fog)]">{copy.relatedLabel}:</span>
      {copy.related.map((r) => (
        <a
          href={r.href}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-1 text-[var(--color-paper)] hover:underline"
        >
          <span>{r.label}</span>
          <svg width="10" height="10" viewBox="0 0 10 10" fill="none">
            <path d="M2 8 L8 2 M8 2 H4 M8 2 V6" stroke="currentColor" stroke-width="1.2" />
          </svg>
        </a>
      ))}
    </div>

    <nav class="mt-6 flex flex-wrap gap-x-6 gap-y-3 text-[11px] uppercase tracking-[var(--tracking-cap)] text-[var(--color-light-grey)]">
      {copy.nav.map((n) => (
        <a href={n.href} class="hover:text-[var(--color-paper)]">{n.label}</a>
      ))}
    </nav>

    <p class="mt-10 pb-10 text-center text-[11px] uppercase tracking-[var(--tracking-cap)] text-[var(--color-fog)]">
      {copy.copyright}
    </p>
    </div>
  </div>
</section>
