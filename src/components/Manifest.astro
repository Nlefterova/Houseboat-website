---
interface Props {
  lang?: "ru" | "en";
}
const { lang = "ru" } = Astro.props;

const copy = lang === "ru"
  ? {
      eyebrow: "Философия KARTEL",
      title: "Не для Москвы. Для настоящей природы.",
      lede:
        "Мы создаём новую культуру отдыха на воде. KARTEL — это право на свободу маршрута: доступ к эмоциям, приключениям и стилю жизни, которые невозможно купить иначе.",
      body1:
        "Люди не покупают катер ради техники — они покупают новый сценарий жизни: свобода, уверенность и удовольствие от контроля над собственным маршрутом.",
      body2:
        "Expedition 65 Lux создан для тех, кто хочет видеть нетронутую тайгу, а не соседний коттаж. Мы используем материалы, которые становятся только красивее со временем.",
      pillars: [
        {
          label: "Для Себя",
          title: "Свобода выбора и максимум возможностей.",
          body: "Личная крепость и автономия. Маршрут, который вы выбираете сами.",
        },
        {
          label: "Для Своих",
          title: "Семья, друзья, патриотизм.",
          body: "Дом, который идёт за впечатлением. Пространство для самых близких.",
        },
      ],
    }
  : {
      eyebrow: "KARTEL Philosophy",
      title: "Not for Moscow. For real wilderness.",
      lede:
        "We're building a new culture of life on water. KARTEL is the right to freedom of route — access to emotions, adventures, and a lifestyle that cannot be bought any other way.",
      body1:
        "People don't buy a vessel for the engineering — they buy a new life-script: freedom, confidence, and the pleasure of controlling their own route.",
      body2:
        "Expedition 65 Lux is built for those who want to see untouched taiga, not the neighbor's dacha. We use materials that only become more beautiful with time.",
      pillars: [
        {
          label: "For Yourself",
          title: "Freedom of choice. Maximum possibility.",
          body: "Personal fortress and autonomy. A route you choose yourself.",
        },
        {
          label: "For Your Circle",
          title: "Family, friends, patriotism.",
          body: "A home that follows experience. Space for the people closest to you.",
        },
      ],
    };
---

<section id="philosophy" class="bg-[var(--color-paper)] py-28 sm:py-36">
  <div class="mx-auto max-w-[1440px] px-8">
    <div class="grid grid-cols-12 gap-x-8 gap-y-12">
      <div class="col-span-12 md:col-span-4">
        <p class="eyebrow">{copy.eyebrow}</p>
        <hr class="rule-ink mt-4" />
      </div>
      <div class="col-span-12 md:col-span-8">
        <h2 class="display text-[40px] leading-[1.05] text-[var(--color-ink)] sm:text-[64px] md:text-[76px]">
          {copy.title}
        </h2>

        <p class="mt-12 max-w-3xl text-[18px] leading-[1.55] text-[var(--color-ink)]">
          {copy.lede}
        </p>

        <div class="mt-10 grid grid-cols-1 gap-x-8 gap-y-6 md:grid-cols-2">
          <p class="text-[15px] leading-[1.7] text-[var(--color-deep-grey)]">{copy.body1}</p>
          <p class="text-[15px] leading-[1.7] text-[var(--color-deep-grey)]">{copy.body2}</p>
        </div>

        <div class="mt-16 grid grid-cols-1 gap-px bg-[var(--color-grey)] sm:grid-cols-2">
          {copy.pillars.map((p) => (
            <article class="bg-[var(--color-paper)] p-8">
              <p class="text-[10px] uppercase tracking-[var(--tracking-wide-cap)] text-[var(--color-fog)]">
                {p.label}
              </p>
              <h3 class="display mt-4 text-[26px] leading-[1.15] text-[var(--color-ink)]">{p.title}</h3>
              <p class="mt-3 text-[14px] leading-[1.65] text-[var(--color-deep-grey)]">{p.body}</p>
            </article>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
