---
import ResponsiveImage from "./ResponsiveImage.astro";
interface Props {
  lang?: "ru" | "en";
}
const { lang = "ru" } = Astro.props;

const copy = lang === "ru"
  ? {
      eyebrow: "Планировка",
      title: "Палубы",
      lede: "Три палубы. Главная — салон и большой камбуз. Нижняя — каюты, сауна, моторный отсек. Верхняя — открытый солярий с арками.",
      fullscreenLabel: "На весь экран",
      closeLabel: "Закрыть",
      placeholder: "Чертёж в работе",
    }
  : {
      eyebrow: "Layouts",
      title: "Decks",
      lede: "Three decks. Main — salon and main galley. Lower — cabins, sauna, engine room. Upper — open solarium with arches.",
      fullscreenLabel: "Fullscreen",
      closeLabel: "Close",
      placeholder: "Drawing in progress",
    };

const decks = lang === "ru"
  ? [
      { key: "upper", label: "Верхняя палуба", labelShort: "Верхняя", caption: "Открытая палуба под тентом, лаунж-зона, обзор 360°", src: "layouts/deck-upper.svg", plan: "layouts/plan-upper.jpg" },
      { key: "main", label: "Главная палуба", labelShort: "Главная", caption: "Кают-компания, верхний камбуз, обеденная на 12 человек, санузел", src: "layouts/deck-main.svg", plan: "layouts/plan-main.jpg" },
      { key: "lower", label: "Нижняя палуба", labelShort: "Нижняя", caption: "Мастер-каюта, 2 гостевые каюты, 2 детские каюты, нижний камбуз, три санузла, СПА, сауна", src: "layouts/deck-lower.svg", plan: "layouts/plan-lower.jpg" },
      { key: "profile", label: "Профиль", labelShort: "Профиль", caption: "Длина 19,6 м · Ширина 5,55 м · Осадка 0,55 м · 30 т · 3 палубы · 5 кают", src: "layouts/deck-full.svg", plan: "layouts/plan-profile.jpg" },
    ]
  : [
      { key: "upper", label: "Upper Deck", labelShort: "Upper", caption: "Upper deck · Solarium", src: "layouts/deck-upper.svg", plan: "layouts/plan-upper.jpg" },
      { key: "main", label: "Main Deck", labelShort: "Main", caption: "Main deck · Salon + galley", src: "layouts/deck-main.svg", plan: "layouts/plan-main.jpg" },
      { key: "lower", label: "Lower Deck", labelShort: "Lower", caption: "Lower deck · Cabins + sauna", src: "layouts/deck-lower.svg", plan: "layouts/plan-lower.jpg" },
      { key: "profile", label: "Profile", labelShort: "Profile", caption: "Side profile", src: "layouts/deck-full.svg", plan: "layouts/plan-profile.jpg" },
    ];

// Default active = Main deck (matches Bering Levanna 70 default)
const activeIndex = 1;

// Natural pixel dims per deck key — width/height aspect-ratio hints. All 4
// deck SVGs share the same 1451x491 viewBox; plan JPGs vary.
const PLAN_DIMS: Record<string, [number, number]> = {
  upper:   [2400, 820],
  main:    [2400, 766],
  lower:   [2400, 766],
  profile: [2400, 1083],
};
const DECK_W = 1451;
const DECK_H = 491;
---

<section id="layouts" class="bg-[var(--color-paper)] py-16 sm:pt-[120px] sm:pb-0">
  <div class="mx-auto max-w-[1440px] px-8">
    <!-- Section header (compact — matches Exterior/Interior, no lede) -->
    <div class="pb-6">
      <p class="eyebrow">{copy.eyebrow}</p>
      <hr class="rule-ink mt-2 sm:mt-4" />
      <h2 class="display mt-6 text-[28px] leading-[1.05] text-[var(--color-ink)] sm:text-[48px]">
        {copy.title}
      </h2>
    </div>

    <!-- Card -->
    <div
      class="layouts-card relative -mx-8 bg-[var(--color-light-grey)] p-5 sm:mx-0 sm:rounded-[4px] sm:p-8"
      data-layouts-card
      data-active={activeIndex}
    >
      <!-- Fullscreen-only close.
           Mobile: icon-only white circle sitting above the tab strip (top-right).
           Desktop: text pill at bottom-right (unchanged). -->
      <button
        type="button"
        data-fullscreen-close
        aria-label={copy.closeLabel}
        class="fs-only fs-only-mobile z-10 mb-3 h-10 w-10 items-center justify-center self-end rounded-full bg-[var(--color-paper)] text-[var(--color-ink)] shadow-sm transition-colors hover:text-[var(--color-neon-blue)]"
      >
        <svg width="14" height="14" viewBox="0 0 12 12" fill="none">
          <path
            d="M2 2 L10 10 M10 2 L2 10"
            stroke="currentColor"
            stroke-width="1.4"
            stroke-linecap="square"
          />
        </svg>
      </button>
      <button
        type="button"
        data-fullscreen-close
        aria-label="Close"
        class="btn-secondary fs-only fs-only-desktop absolute bottom-8 right-8 z-10 items-center gap-2 rounded-full px-5 py-2.5 text-[11px] uppercase tracking-[var(--tracking-cap)] shadow-sm"
      >
        <span data-fullscreen-close-label>{copy.closeLabel}</span>
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
          <path
            d="M2 2 L10 10 M10 2 L2 10"
            stroke="currentColor"
            stroke-width="1.2"
            stroke-linecap="square"
          />
        </svg>
      </button>
      <!-- Desktop zoom controls: right-edge of card, vertically centered (original). -->
      <div
        class="fs-only fs-only-desktop absolute right-10 top-1/2 z-10 flex -translate-y-1/2 flex-col gap-3"
      >
        <button
          type="button"
          data-zoom="in"
          aria-label="Zoom in"
          class="flex h-11 w-11 items-center justify-center rounded-full bg-[var(--color-ink)] text-[var(--color-paper)] shadow-sm transition-colors hover:bg-[var(--color-deep-grey)] disabled:cursor-not-allowed disabled:opacity-30"
        >
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M8 3 V13 M3 8 H13" stroke="currentColor" stroke-width="1.6" stroke-linecap="square" />
          </svg>
        </button>
        <button
          type="button"
          data-zoom="out"
          aria-label="Zoom out"
          class="flex h-11 w-11 items-center justify-center rounded-full bg-[var(--color-ink)] text-[var(--color-paper)] shadow-sm transition-colors hover:bg-[var(--color-deep-grey)] disabled:cursor-not-allowed disabled:opacity-30"
        >
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M3 8 H13" stroke="currentColor" stroke-width="1.6" stroke-linecap="square" />
          </svg>
        </button>
      </div>

      <!-- Tab strip -->
      <div
        data-tab-strip
        class="flex flex-wrap items-stretch gap-1 rounded-[4px] bg-[var(--color-grey)] p-1"
      >
        {decks.map((d, i) => (
          <button
            type="button"
            data-tab-index={i}
            class={`flex-1 min-w-0 truncate rounded-[3px] px-2 py-2 text-[9px] uppercase tracking-[var(--tracking-cap)] transition-colors sm:px-4 sm:py-3 sm:text-[11px] ${
              i === activeIndex
                ? "bg-[var(--color-neon-blue)] text-[var(--color-paper)]"
                : "text-[var(--color-deep-grey)] hover:bg-[color-mix(in_srgb,white_60%,transparent)]"
            }`}
          >
            <span class="sm:hidden">{d.labelShort}</span>
            <span class="hidden sm:inline">{d.label}</span>
          </button>
        ))}
      </div>

      <!-- Plan area — top-down deck plan per tab. -->
      <div data-plan-area class="relative mt-6 aspect-[16/8] w-full overflow-hidden rounded-[2px] bg-[var(--color-paper)] sm:aspect-[16/5]">
        <!-- Mobile-only zoom controls: sit in the bottom-right corner of the white plan area. -->
        <div class="fs-only fs-only-mobile absolute bottom-3 right-3 z-10 flex flex-row gap-2">
          <button
            type="button"
            data-zoom="in"
            aria-label="Zoom in"
            class="flex h-9 w-9 items-center justify-center rounded-full bg-[var(--color-ink)] text-[var(--color-paper)] shadow-sm transition-colors hover:bg-[var(--color-deep-grey)] disabled:cursor-not-allowed disabled:opacity-30"
          >
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
              <path d="M8 3 V13 M3 8 H13" stroke="currentColor" stroke-width="1.6" stroke-linecap="square" />
            </svg>
          </button>
          <button
            type="button"
            data-zoom="out"
            aria-label="Zoom out"
            class="flex h-9 w-9 items-center justify-center rounded-full bg-[var(--color-ink)] text-[var(--color-paper)] shadow-sm transition-colors hover:bg-[var(--color-deep-grey)] disabled:cursor-not-allowed disabled:opacity-30"
          >
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
              <path d="M3 8 H13" stroke="currentColor" stroke-width="1.6" stroke-linecap="square" />
            </svg>
          </button>
        </div>
        {decks.map((d, i) => (
          <div
            data-plan-index={i}
            data-deck-caption={d.caption}
            class={`absolute inset-0 flex items-center justify-center p-4 transition-opacity duration-300 ${
              i === activeIndex ? "opacity-100" : "opacity-0"
            }`}
            aria-hidden={i !== activeIndex}
          >
            <ResponsiveImage
              src={d.plan}
              alt={d.caption}
              width={PLAN_DIMS[d.key]?.[0] ?? 2400}
              height={PLAN_DIMS[d.key]?.[1] ?? 820}
              sizes="(min-width: 1024px) 80vw, 100vw"
              loading={i === activeIndex ? "eager" : "lazy"}
              class={`h-full w-full object-contain ${d.key === "profile" ? "scale-[1.15] translate-y-[20px]" : ""}`}
            />
          </div>
        ))}
      </div>

      <!-- Side-profile guide — sits on the grey card, shows which deck is active.
           Not the layout sketch; an orientation strip like Bering Levanna 70. -->
      <div class="relative mt-5 aspect-[1451/491] w-full max-w-[240px] mx-auto sm:max-w-[400px]">
        {decks.map((d, i) => (
          <img
            data-guide-index={i}
            src={d.src}
            alt=""
            width={DECK_W}
            height={DECK_H}
            loading={i === activeIndex ? "eager" : "lazy"}
            aria-hidden="true"
            class={`absolute inset-0 h-full w-full object-contain transition-opacity duration-300 ${
              i === activeIndex ? "opacity-100" : "opacity-0"
            }`}
          />
        ))}
      </div>

      <!-- Caption centered directly under the guide -->
      <p
        data-active-caption
        class="mt-3 text-center text-[11px] font-medium text-[var(--color-ink)] sm:text-[16px]"
      >
        {decks[activeIndex].caption}
      </p>

      <!-- Fullscreen pill, right-aligned on its own row.
           Hidden in fullscreen mode — top-right X handles closing instead. -->
      <div class="fs-hide mt-4 flex justify-end">
        <!-- Mobile: icon-only white circle -->
        <button
          type="button"
          data-fullscreen-toggle
          data-open-label={copy.fullscreenLabel}
          data-close-label={copy.closeLabel}
          aria-label={copy.fullscreenLabel}
          class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-[var(--color-paper)] text-[var(--color-ink)] shadow-sm transition-colors hover:text-[var(--color-neon-blue)] sm:hidden"
        >
          <svg data-fullscreen-icon-open width="14" height="14" viewBox="0 0 12 12" fill="none">
            <path
              d="M2 7 V10 H5 M10 5 V2 H7 M2 10 L5 7 M10 2 L7 5"
              stroke="currentColor"
              stroke-width="1.2"
              stroke-linecap="square"
            />
          </svg>
          <svg data-fullscreen-icon-close width="14" height="14" viewBox="0 0 12 12" fill="none" class="hidden">
            <path
              d="M2 2 L10 10 M10 2 L2 10"
              stroke="currentColor"
              stroke-width="1.2"
              stroke-linecap="square"
            />
          </svg>
        </button>
        <!-- Desktop: text pill -->
        <button
          type="button"
          data-fullscreen-toggle
          data-open-label={copy.fullscreenLabel}
          data-close-label={copy.closeLabel}
          class="btn-secondary hidden items-center gap-2 rounded-full px-5 py-2.5 text-[11px] uppercase tracking-[var(--tracking-cap)] sm:inline-flex"
        >
          <span data-fullscreen-label>{copy.fullscreenLabel}</span>
          <svg data-fullscreen-icon-open width="12" height="12" viewBox="0 0 12 12" fill="none">
            <path
              d="M2 7 V10 H5 M10 5 V2 H7 M2 10 L5 7 M10 2 L7 5"
              stroke="currentColor"
              stroke-width="1.2"
              stroke-linecap="square"
            />
          </svg>
          <svg data-fullscreen-icon-close width="12" height="12" viewBox="0 0 12 12" fill="none" class="hidden">
            <path
              d="M2 2 L10 10 M10 2 L2 10"
              stroke="currentColor"
              stroke-width="1.2"
              stroke-linecap="square"
            />
          </svg>
        </button>
      </div>
    </div>
  </div>
</section>

<style>
  .layouts-card .fs-only { display: none; }
  .layouts-card.is-fullscreen { display: flex; }
  .layouts-card.is-fullscreen .fs-only { display: inline-flex; }
  .layouts-card.is-fullscreen .fs-hide { display: none; }
  /* Show only the mobile close on <640px fullscreen, only the desktop pill on >=640px */
  @media (min-width: 640px) {
    .layouts-card.is-fullscreen .fs-only-mobile { display: none; }
  }
  @media (max-width: 639px) {
    .layouts-card.is-fullscreen .fs-only-desktop { display: none; }
  }
  .layouts-card.is-fullscreen {
    position: fixed;
    inset: 0;
    z-index: 50;
    margin: 0;
    max-width: none;
    border-radius: 0;
    flex-direction: column;
    overflow-y: auto;
  }
  .layouts-card.is-fullscreen [data-plan-area] {
    aspect-ratio: auto;
    flex: 1 1 auto;
    min-height: 0;
  }
  @media (max-width: 639px) {
    .layouts-card.is-fullscreen [data-plan-area] {
      flex: 0 0 auto;
      height: 50vh;
    }
    .layouts-card.is-fullscreen [data-active-caption] {
      font-size: 15px;
    }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>("[data-layouts-card]").forEach((root) => {
    const tabs = root.querySelectorAll<HTMLElement>("[data-tab-index]");
    const plans = root.querySelectorAll<HTMLElement>("[data-plan-index]");
    const guides = root.querySelectorAll<HTMLElement>("[data-guide-index]");
    const caption = root.querySelector<HTMLElement>("[data-active-caption]");
    const fsBtns = root.querySelectorAll<HTMLButtonElement>("[data-fullscreen-toggle]");
    const fsBtn = fsBtns[0];
    const fsLabels = root.querySelectorAll<HTMLElement>("[data-fullscreen-label]");
    const fsIconOpens = root.querySelectorAll<HTMLElement>("[data-fullscreen-icon-open]");
    const fsIconCloses = root.querySelectorAll<HTMLElement>("[data-fullscreen-icon-close]");
    const fsCloseBtns = root.querySelectorAll<HTMLButtonElement>("[data-fullscreen-close]");
    const zoomInBtns = root.querySelectorAll<HTMLButtonElement>('[data-zoom="in"]');
    const zoomOutBtns = root.querySelectorAll<HTMLButtonElement>('[data-zoom="out"]');

    const ZOOM_LEVELS = [1.0, 1.5, 2.0, 2.5];
    let zoomIndex = 0;
    let panX = 0;
    let panY = 0;
    let isDragging = false;
    let dragStartX = 0;
    let dragStartY = 0;
    let panStartX = 0;
    let panStartY = 0;
    let currentTab = Number(root.dataset.active ?? 0);

    function applyTransform() {
      const active = plans[currentTab]?.querySelector("img") as HTMLImageElement | null;
      plans.forEach((p) => {
        const img = p.querySelector("img") as HTMLImageElement | null;
        if (img) {
          img.style.transform = "";
          img.style.cursor = "";
          img.style.touchAction = "";
        }
      });
      if (active && zoomIndex > 0) {
        const s = ZOOM_LEVELS[zoomIndex];
        active.style.transform = `translate(${panX}px, ${panY}px) scale(${s})`;
        active.style.cursor = isDragging ? "grabbing" : "grab";
        active.style.touchAction = "none";
      }
      zoomInBtns.forEach((b) => (b.disabled = zoomIndex >= ZOOM_LEVELS.length - 1));
      zoomOutBtns.forEach((b) => (b.disabled = zoomIndex <= 0));
    }

    function applyZoom() {
      panX = 0;
      panY = 0;
      applyTransform();
    }

    function activate(i: number) {
      currentTab = i;
      tabs.forEach((t, idx) => {
        if (idx === i) {
          t.classList.add("bg-[var(--color-neon-blue)]", "text-[var(--color-paper)]");
          t.classList.remove(
            "text-[var(--color-deep-grey)]",
            "hover:bg-[color-mix(in_srgb,white_60%,transparent)]"
          );
        } else {
          t.classList.remove("bg-[var(--color-neon-blue)]", "text-[var(--color-paper)]");
          t.classList.add(
            "text-[var(--color-deep-grey)]",
            "hover:bg-[color-mix(in_srgb,white_60%,transparent)]"
          );
        }
      });
      plans.forEach((p, idx) => {
        p.style.opacity = idx === i ? "1" : "0";
        p.setAttribute("aria-hidden", idx === i ? "false" : "true");
      });
      guides.forEach((g, idx) => {
        g.style.opacity = idx === i ? "1" : "0";
      });
      const active = plans[i] as HTMLElement | undefined;
      if (active && caption) {
        const cap = active.dataset.deckCaption ?? "";
        if (cap) caption.textContent = cap;
      }
      zoomIndex = 0;
      applyZoom();
    }

    tabs.forEach((t) => {
      t.addEventListener("click", () => {
        const i = Number(t.dataset.tabIndex);
        activate(i);
      });
    });

    function setFullscreen(on: boolean) {
      root.classList.toggle("is-fullscreen", on);
      document.body.style.overflow = on ? "hidden" : "";
      if (fsBtn) {
        const label = on
          ? fsBtn.dataset.closeLabel ?? "Close"
          : fsBtn.dataset.openLabel ?? "Fullscreen";
        fsLabels.forEach((el) => (el.textContent = label));
      }
      fsIconOpens.forEach((el) => el.classList.toggle("hidden", on));
      fsIconCloses.forEach((el) => el.classList.toggle("hidden", !on));
      if (!on) {
        zoomIndex = 0;
        applyZoom();
      }
    }

    fsBtns.forEach((btn) =>
      btn.addEventListener("click", () => {
        setFullscreen(!root.classList.contains("is-fullscreen"));
      })
    );

    fsCloseBtns.forEach((btn) => btn.addEventListener("click", () => setFullscreen(false)));

    zoomInBtns.forEach((b) =>
      b.addEventListener("click", () => {
        if (zoomIndex < ZOOM_LEVELS.length - 1) {
          zoomIndex++;
          applyZoom();
        }
      })
    );

    zoomOutBtns.forEach((b) =>
      b.addEventListener("click", () => {
        if (zoomIndex > 0) {
          zoomIndex--;
          applyZoom();
        }
      })
    );

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && root.classList.contains("is-fullscreen")) {
        setFullscreen(false);
      }
    });

    // Pan when zoomed — pointer events handle mouse, touch, and pen uniformly.
    plans.forEach((p) => {
      const img = p.querySelector("img") as HTMLImageElement | null;
      if (!img) return;

      img.addEventListener("pointerdown", (e) => {
        if (zoomIndex === 0) return;
        isDragging = true;
        dragStartX = e.clientX;
        dragStartY = e.clientY;
        panStartX = panX;
        panStartY = panY;
        img.setPointerCapture(e.pointerId);
        img.style.cursor = "grabbing";
        e.preventDefault();
      });

      img.addEventListener("pointermove", (e) => {
        if (!isDragging) return;
        panX = panStartX + (e.clientX - dragStartX);
        panY = panStartY + (e.clientY - dragStartY);
        applyTransform();
      });

      const endDrag = (e: PointerEvent) => {
        if (!isDragging) return;
        isDragging = false;
        if (img.hasPointerCapture(e.pointerId)) {
          img.releasePointerCapture(e.pointerId);
        }
        img.style.cursor = zoomIndex > 0 ? "grab" : "";
      };
      img.addEventListener("pointerup", endDrag);
      img.addEventListener("pointercancel", endDrag);

      // Block native drag-ghost (Safari/Chrome show a translucent copy on mousedown).
      img.addEventListener("dragstart", (e) => e.preventDefault());
    });

    applyZoom();
  });
</script>
