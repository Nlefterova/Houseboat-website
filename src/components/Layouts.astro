---
interface Props {
  lang?: "ru" | "en";
}
const { lang = "ru" } = Astro.props;

const copy = lang === "ru"
  ? {
      eyebrow: "Планировка",
      title: "Палубы",
      lede: "Три палубы. Главная — салон и большой камбуз. Нижняя — каюты, сауна, моторный отсек. Верхняя — открытый солярий с арками.",
      fullscreenLabel: "На весь экран",
      placeholder: "Чертёж в работе",
    }
  : {
      eyebrow: "Layouts",
      title: "Decks",
      lede: "Three decks. Main — salon and main galley. Lower — cabins, sauna, engine room. Upper — open solarium with arches.",
      fullscreenLabel: "Fullscreen",
      placeholder: "Drawing in progress",
    };

const decks = lang === "ru"
  ? [
      { key: "upper", label: "Верхняя палуба", caption: "Верхняя палуба · Солярий" },
      { key: "main", label: "Главная палуба", caption: "Главная палуба · Салон + камбуз" },
      { key: "lower", label: "Нижняя палуба", caption: "Нижняя палуба · Каюты + сауна" },
      { key: "profile", label: "Профиль", caption: "Боковой профиль" },
    ]
  : [
      { key: "upper", label: "Upper Deck", caption: "Upper deck · Solarium" },
      { key: "main", label: "Main Deck", caption: "Main deck · Salon + galley" },
      { key: "lower", label: "Lower Deck", caption: "Lower deck · Cabins + sauna" },
      { key: "profile", label: "Profile", caption: "Side profile" },
    ];

// Default active = Main deck (matches Bering Levanna 70 default)
const activeIndex = 1;
---

<section id="layouts" class="bg-[var(--color-paper)] py-12 sm:py-16">
  <div class="mx-auto max-w-[1440px] px-8">
    <!-- Section header (matches Exterior/Interior style) -->
    <div class="grid grid-cols-12 gap-x-8 gap-y-4 pb-6">
      <div class="col-span-12 lg:col-span-5">
        <p class="eyebrow">{copy.eyebrow}</p>
        <hr class="rule-ink mt-4" />
        <h2
          class="display mt-6 text-[32px] leading-[1.05] text-[var(--color-ink)] sm:text-[44px]"
        >
          {copy.title}
        </h2>
      </div>
      <div class="col-span-12 lg:col-span-7 lg:pt-2">
        <p class="max-w-xl text-[14px] leading-[1.6] text-[var(--color-deep-grey)]">
          {copy.lede}
        </p>
      </div>
    </div>

    <!-- Card -->
    <div
      class="rounded-[4px] bg-[var(--color-light-grey)] p-6 sm:p-10"
      data-layouts-card
      data-active={activeIndex}
    >
      <!-- Tab strip -->
      <div
        class="flex flex-wrap items-stretch gap-1 rounded-[4px] bg-[var(--color-grey)] p-1"
      >
        {decks.map((d, i) => (
          <button
            type="button"
            data-tab-index={i}
            class={`flex-1 min-w-0 rounded-[3px] px-4 py-3 text-[11px] uppercase tracking-[var(--tracking-cap)] transition-colors ${
              i === activeIndex
                ? "bg-[var(--color-ink)] text-[var(--color-paper)]"
                : "text-[var(--color-deep-grey)] hover:bg-[color-mix(in_srgb,white_60%,transparent)]"
            }`}
          >
            {d.label}
          </button>
        ))}
      </div>

      <!-- Plan area -->
      <div class="relative mt-8 aspect-[16/7] w-full overflow-hidden rounded-[2px] bg-[var(--color-paper)]">
        {decks.map((d, i) => (
          <div
            data-plan-index={i}
            data-deck-caption={d.caption}
            class={`absolute inset-0 flex items-center justify-center transition-opacity duration-300 ${
              i === activeIndex ? "opacity-100" : "opacity-0"
            }`}
            aria-hidden={i !== activeIndex}
          >
            <!-- Placeholder schematic: top-down boat silhouette suggestion + label -->
            <svg
              viewBox="0 0 800 200"
              class="h-auto w-[80%] max-w-[900px] text-[var(--color-deep-grey)] opacity-30"
              fill="none"
              stroke="currentColor"
              stroke-width="1.2"
            >
              <path d="M30 100 C 80 60, 180 40, 360 40 L 640 40 C 720 40, 760 80, 780 100 C 760 120, 720 160, 640 160 L 360 160 C 180 160, 80 140, 30 100 Z" />
              <line x1="180" y1="55" x2="180" y2="145" />
              <line x1="320" y1="50" x2="320" y2="150" />
              <line x1="480" y1="50" x2="480" y2="150" />
              <line x1="620" y1="55" x2="620" y2="145" />
            </svg>
            <span class="absolute top-6 left-6 text-[10px] uppercase tracking-[var(--tracking-wide-cap)] text-[color-mix(in_srgb,black_45%,transparent)]">
              [{copy.placeholder}] · {d.key}
            </span>
          </div>
        ))}
      </div>

      <!-- Profile silhouette + caption + fullscreen pill -->
      <div class="mt-10 grid grid-cols-12 items-end gap-x-6 gap-y-4">
        <div class="col-span-12 sm:col-span-3 sm:col-start-1"></div>
        <div class="col-span-12 sm:col-span-6 flex flex-col items-center">
          <!-- Small profile silhouette -->
          <svg
            viewBox="0 0 400 60"
            class="h-auto w-[60%] max-w-[280px] text-[var(--color-deep-grey)] opacity-50"
            fill="none"
            stroke="currentColor"
            stroke-width="1"
          >
            <path d="M20 45 L 350 45 C 370 45, 380 40, 380 32 L 380 28 C 380 22, 370 18, 355 18 L 220 18 L 215 4 L 195 4 L 192 18 L 60 18 C 35 18, 20 30, 20 45 Z" />
            <line x1="40" y1="36" x2="80" y2="36" stroke-width="0.6" />
            <line x1="100" y1="36" x2="140" y2="36" stroke-width="0.6" />
            <line x1="160" y1="36" x2="200" y2="36" stroke-width="0.6" />
            <line x1="220" y1="36" x2="260" y2="36" stroke-width="0.6" />
            <line x1="280" y1="36" x2="320" y2="36" stroke-width="0.6" />
          </svg>
          <p
            data-deck-caption
            class="mt-4 text-[16px] font-medium text-[var(--color-ink)] sm:text-[18px]"
          >
            {decks[activeIndex].caption}
          </p>
        </div>
        <div class="col-span-12 sm:col-span-3 sm:text-right">
          <button
            type="button"
            class="inline-flex items-center gap-2 rounded-full bg-[var(--color-paper)] px-5 py-2.5 text-[11px] uppercase tracking-[var(--tracking-cap)] text-[var(--color-ink)] transition-colors hover:bg-[var(--color-ink)] hover:text-[var(--color-paper)]"
          >
            <span>{copy.fullscreenLabel}</span>
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
              <path
                d="M2 7 V10 H5 M10 5 V2 H7 M2 10 L5 7 M10 2 L7 5"
                stroke="currentColor"
                stroke-width="1.2"
                stroke-linecap="square"
              />
            </svg>
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLElement>("[data-layouts-card]").forEach((root) => {
    const tabs = root.querySelectorAll<HTMLElement>("[data-tab-index]");
    const plans = root.querySelectorAll<HTMLElement>("[data-plan-index]");
    const caption = root.querySelector<HTMLElement>("[data-deck-caption]");
    const captions = Array.from(plans).map(
      (el) => el.querySelector<HTMLElement>("[data-deck-cap]")?.textContent ?? ""
    );

    // Collect captions from the rendered DOM-side data (server-rendered initial)
    const captionTexts: string[] = [];
    tabs.forEach((t) => {
      const idx = Number(t.dataset.tabIndex);
      captionTexts[idx] = t.textContent?.trim() ?? "";
    });

    function activate(i: number) {
      tabs.forEach((t, idx) => {
        if (idx === i) {
          t.classList.add("bg-[var(--color-ink)]", "text-[var(--color-paper)]");
          t.classList.remove(
            "text-[var(--color-deep-grey)]",
            "hover:bg-[color-mix(in_srgb,white_60%,transparent)]"
          );
        } else {
          t.classList.remove("bg-[var(--color-ink)]", "text-[var(--color-paper)]");
          t.classList.add(
            "text-[var(--color-deep-grey)]",
            "hover:bg-[color-mix(in_srgb,white_60%,transparent)]"
          );
        }
      });
      plans.forEach((p, idx) => {
        p.style.opacity = idx === i ? "1" : "0";
        p.setAttribute("aria-hidden", idx === i ? "false" : "true");
      });
      // Update caption from a data attribute mirrored on each plan
      const active = plans[i] as HTMLElement | undefined;
      if (active && caption) {
        const cap = active.dataset.deckCaption ?? "";
        if (cap) caption.textContent = cap;
      }
    }

    tabs.forEach((t) => {
      t.addEventListener("click", () => {
        const i = Number(t.dataset.tabIndex);
        activate(i);
      });
    });
  });
</script>
