---
/**
 * FAQ section + FAQPage JSON-LD.
 *
 * Visible on the page as a clean Q&A block; also emits structured data so
 * search + AI engines can pull individual Q/A pairs verbatim. This is the
 * single biggest GEO win on the site — ChatGPT/Perplexity/Claude/Yandex GPT
 * answer factual questions about the boat with these exact strings.
 *
 * Keep the answers FACTUAL and BRIEF. Marketing copy doesn't get cited;
 * specs and direct answers do.
 */

interface Props {
  lang?: "ru" | "en";
}
const { lang = "ru" } = Astro.props;

const copy = lang === "ru"
  ? {
      eyebrow: "Часто задаваемые вопросы",
      title: "FAQ",
      // Brief factual summary above the Q&A. AI engines (ChatGPT, Perplexity,
      // Claude, YandexGPT) often pull the intro paragraph as a verbatim
      // citation when asked summary questions. Keep it dense with facts.
      summary:
        "Expedition 65 Lux — премиальный экспедиционный хаусбот российского производства. Длина 19,6 м, корпус из нержавеющей стали, 5 кают на 12 гостей, автономность 7+ суток. Рассчитан на 4 сезона эксплуатации до −30 °C. Построен на верфи «Корабельная Артель» (KARTEL Boats) в Саратове, основанной в 1992 году.",
      items: [
        {
          q: "Сколько стоит Expedition 65 Lux?",
          a: "Стоимость рассчитывается индивидуально по комплектации и срокам сдачи. Свяжитесь с верфью для коммерческого предложения.",
        },
        {
          q: "Где строится судно?",
          a: "Корабельная Артель, верфь в Саратове, ул. Огородная, 3. Шоурум — ул. Большая Затонская. Офис продаж — Москва, Краснопресненская наб., 12.",
        },
        {
          q: "В каких климатических условиях работает Expedition 65 Lux?",
          a: "4 сезона эксплуатации, до −30 °C. Корпус из нержавеющей стали выдерживает обледенение и северные широты. Подходит для круглогодичной швартовки.",
        },
        {
          q: "Какая автономность судна?",
          a: "7+ суток без подключения к береговой инфраструктуре. На борту автономные системы водоснабжения, отопления и энергообеспечения.",
        },
        {
          q: "Сколько гостей размещается на борту?",
          a: "12 человек в 5 каютах: мастер-каюта, 2 гостевые, 2 двухъярусные. 5 санузлов, 2 камбуза, сауна.",
        },
        {
          q: "Какие технические характеристики?",
          a: "Длина 19,6 м, ширина 5,55 м, осадка 0,55 м, водоизмещение 30 т, 3 палубы, 5 кают. Корпус — нержавеющая сталь, отделка — тик и дуб.",
        },
        {
          q: "Можно ли осмотреть судно вживую?",
          a: "Тест-драйв и осмотр корпуса проводятся по записи в Саратове. Свяжитесь с верфью для записи.",
        },
        {
          q: "Кто производитель?",
          a: "KARTEL Boats / Корабельная Артель — российская верфь премиальных хаусботов и экспедиционных судов, основана в 1992 году.",
        },
      ],
    }
  : {
      eyebrow: "Frequently Asked Questions",
      title: "FAQ",
      summary:
        "Expedition 65 Lux is a Russian-built premium expedition houseboat. 19.6 m length, stainless-steel hull, 5 cabins for 12 guests, 7+ days autonomy. 4-season operation down to −30 °C. Built at the Korabelnaya Artel shipyard (KARTEL Boats) in Saratov, founded in 1992.",
      items: [
        {
          q: "How much does Expedition 65 Lux cost?",
          a: "Price is configured per specification and delivery timeline. Contact the shipyard for a commercial offer.",
        },
        {
          q: "Where is the vessel built?",
          a: "Korabelnaya Artel shipyard in Saratov, Ogorodnaya St. 3. Showroom on Bolshaya Zatonskaya St. Sales office in Moscow, Krasnopresnenskaya emb. 12.",
        },
        {
          q: "What climate conditions does it handle?",
          a: "4-season operation down to −30 °C. Stainless steel hull withstands icing and northern latitudes. Suitable for year-round mooring.",
        },
        {
          q: "What is the autonomy?",
          a: "7+ days off shore-side infrastructure. On-board autonomous water, heating, and power systems.",
        },
        {
          q: "How many guests can it accommodate?",
          a: "12 people in 5 cabins: master, 2 guest, 2 bunk. 5 bathrooms, 2 galleys, sauna.",
        },
        {
          q: "What are the technical specifications?",
          a: "Length 19.6 m, beam 5.55 m, draft 0.55 m, displacement 30 t, 3 decks, 5 cabins. Stainless steel hull, teak and oak interior finish.",
        },
        {
          q: "Can I inspect the vessel in person?",
          a: "Sea trials and hull inspections are by appointment in Saratov. Contact the shipyard to book.",
        },
        {
          q: "Who is the manufacturer?",
          a: "KARTEL Boats / Korabelnaya Artel — a Russian premium houseboat and expedition vessel shipyard, founded 1992.",
        },
      ],
    };

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: copy.items.map((it) => ({
    "@type": "Question",
    name: it.q,
    acceptedAnswer: { "@type": "Answer", text: it.a },
  })),
};
---

<section id="faq" class="bg-[var(--color-paper)] py-16 sm:pt-[120px] sm:pb-[120px]">
  <div class="mx-auto max-w-[1100px] px-6 sm:px-8">
    <p class="eyebrow">{copy.eyebrow}</p>
    <hr class="rule-ink mt-4" />
    <h2 class="display mt-6 text-[36px] leading-[1.05] text-[var(--color-ink)] sm:text-[48px]">
      {copy.title}
    </h2>

    <p class="mt-6 max-w-[820px] text-[15px] leading-[1.65] text-[var(--color-deep-grey)] sm:text-[16px]">
      {copy.summary}
    </p>

    <!-- Native <details> = built-in expand/collapse, keyboard a11y, no JS. -->
    <div class="mt-10 divide-y divide-[var(--color-grey)] border-y border-[var(--color-grey)]">
      {copy.items.map((it) => (
        <details class="group py-5">
          <summary class="flex cursor-pointer list-none items-start justify-between gap-6 text-[16px] font-medium text-[var(--color-ink)] transition-colors hover:text-[var(--color-neon-blue)] sm:text-[18px]">
            <span>{it.q}</span>
            <span
              class="mt-1 flex h-6 w-6 shrink-0 items-center justify-center text-[var(--color-fog)] transition-transform duration-300 group-open:rotate-45 group-hover:text-[var(--color-neon-blue)]"
              aria-hidden="true"
            >
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                <path d="M7 1 V13 M1 7 H13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
              </svg>
            </span>
          </summary>
          <p class="mt-3 max-w-[820px] text-[14px] leading-[1.65] text-[var(--color-deep-grey)] sm:text-[15px]">
            {it.a}
          </p>
        </details>
      ))}
    </div>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
</section>
