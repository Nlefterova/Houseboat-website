---
interface Props {
  lang?: "ru" | "en";
}
const { lang = "ru" } = Astro.props;

const copy = lang === "ru"
  ? {
      // Block 1 — Корабельная Артель intro
      eyebrow: "Корабельная Артель · 1992",
      title: "30 лет на Волге.",
      body:
        "Верфь основана в Саратове в 1992 году. За три десятилетия — десятки уникальных судов, спроектированных, построенных и спущенных на воду собственными силами.",
      vessels: [
        { name: "Borei 62", type: "Luxury · река-море", photo: "heritage/borei-62.jpg" },
        { name: "Poseidon 90", type: "Экспедиционный корабль", photo: "heritage/poseidon-90.jpg" },
        { name: "Calypso 65", type: "Премиум круизер", photo: "heritage/calypso-65.jpg" },
        { name: "Piligrim 65", type: "Траулер · экспедиция", photo: "heritage/piligrim-65.jpg" },
      ],
      // Block 2 — Heritage & Legacy
      legacyEyebrow: "Наследие и история",
      legacyTitle: "От «Сибирского Исследователя» к вашему проекту.",
      legacyBody1:
        "История проекта началась в суровых водах Енисея. Наш предыдущий проект, «Сибирский исследователь», был создан для РГО.",
      legacyBody2:
        "Мы применили тот же бескомпромиссный инженерный подход: корпус из нержавеющей стали для прохождения льдов, автономность на недели вперёд и технологии выживания. Expedition 65 Lux — гражданская версия экспедиционного судна. Роскошь, защищённая бронёй.",
      legacyChips: [
        { label: "Надёжность", value: "Технологии РГО" },
        { label: "Статус", value: "Экспедиционный класс" },
      ],
      videoChip: "Проект-предшественник",
      videoCaption: "Сибирский Исследователь · 2 мин",
      videoNote: "Видео загружается",
      // Block 3 — Strategic Partnership (RGO)
      partnerEyebrow: "Стратегическое партнёрство · EST. 1845",
      partnerTitle: "Русское географическое общество",
      partnerBody:
        "Флагман «Сибирский исследователь» — 18-метровый стальной корабль класса «река-море», созданный на наших стапелях для выполнения миссий РГО в высоких широтах Арктики.",
      partnerStats: [
        { value: "18м", label: "Длина судна" },
        { value: "09Г2С", label: "Нержавеющая сталь" },
        { value: "1300", label: "Миль автономии" },
      ],
      forbesQuote:
        "Особенность судна — защитные накладки, усиливающие киль вдвое. Это позволяет работать в условиях сложной навигации, недоступных для обычных яхт.",
      forbesAttr: "Forbes Russia",
      rgoCta: "Проект на rgo.ru",
    }
  : {
      eyebrow: "Korabelnaya Artel · 1992",
      title: "30 years on the Volga.",
      body:
        "Shipyard founded in Saratov in 1992. Three decades — dozens of unique vessels, designed, built and launched in-house.",
      vessels: [
        { name: "Borei 62", type: "Luxury · river-sea", photo: "heritage/borei-62.jpg" },
        { name: "Poseidon 90", type: "Expedition vessel", photo: "heritage/poseidon-90.jpg" },
        { name: "Calypso 65", type: "Premium cruiser", photo: "heritage/calypso-65.jpg" },
        { name: "Piligrim 65", type: "Trawler · expedition", photo: "heritage/piligrim-65.jpg" },
      ],
      legacyEyebrow: "Heritage & Legacy",
      legacyTitle: "From the Siberian Explorer to your project.",
      legacyBody1:
        "The project began in the harsh waters of the Yenisei. Our previous build, Siberian Explorer, was made for the Russian Geographical Society.",
      legacyBody2:
        "We applied the same uncompromising engineering: stainless-steel hull for breaking through ice, autonomy for weeks ahead, survival-grade technology. Expedition 65 Lux — the civilian version of an expedition vessel. Luxury protected by armor.",
      legacyChips: [
        { label: "Reliability", value: "RGS-grade build" },
        { label: "Status", value: "Expedition class" },
      ],
      videoChip: "Predecessor Project",
      videoCaption: "Siberian Explorer · 2 min",
      videoNote: "Video loading",
      partnerEyebrow: "Strategic Partnership · EST. 1845",
      partnerTitle: "Russian Geographical Society",
      partnerBody:
        "Flagship Siberian Explorer — an 18-metre steel river-sea class vessel built on our slipways for RGS missions in the high Arctic.",
      partnerStats: [
        { value: "18m", label: "Vessel length" },
        { value: "09G2S", label: "Stainless steel hull" },
        { value: "1300", label: "Nautical miles" },
      ],
      forbesQuote:
        "A distinguishing feature of the vessel is the protective overlays that double the keel strength. This allows it to work in complex navigation conditions inaccessible to ordinary yachts.",
      forbesAttr: "Forbes Russia",
      rgoCta: "Project on rgo.ru",
    };
---

<section id="heritage" class="border-t border-[var(--color-grey)] bg-[var(--color-paper)] py-16 sm:py-24">
  <div class="mx-auto max-w-[1440px] px-8">
    <!-- BLOCK 1 — Корабельная Артель intro + vessels -->
    <div>
      <p class="eyebrow">{copy.eyebrow}</p>
      <hr class="rule-ink mt-4" />
      <h2 class="display mt-6 text-[36px] leading-[1.05] text-[var(--color-ink)] sm:text-[48px]">
        {copy.title}
      </h2>
      <p class="mt-6 max-w-[640px] text-[14px] leading-[1.65] text-[var(--color-deep-grey)] sm:text-[15px]">
        {copy.body}
      </p>
    </div>

    <!-- Vessel grid — photo card with caption strip below. -->
    <div class="mt-10 grid grid-cols-2 gap-3 sm:grid-cols-4 sm:gap-4">
      {copy.vessels.map((v) => (
        <article class="relative flex flex-col border border-[var(--color-grey)] bg-[var(--color-paper)] p-5 sm:p-6">
          <!-- Blue top accent strip — matches the Locations cards -->
          <span class="absolute inset-x-0 top-0 h-[3px] bg-[var(--color-neon-blue)]"></span>
          <div class="aspect-[5/4] w-full">
            <img
              src={v.photo}
              alt={v.name}
              loading="lazy"
              class="h-full w-full object-contain"
            />
          </div>
          <div class="mt-4">
            <p class="text-[10px] uppercase tracking-[var(--tracking-wide-cap)] text-[var(--color-fog)]">
              {v.type}
            </p>
            <h3 class="display mt-1 text-[20px] leading-[1.1] text-[var(--color-ink)] sm:text-[22px]">
              {v.name}
            </h3>
          </div>
        </article>
      ))}
    </div>

    <!-- History CTA — links to the Kartel shipyard site -->
    <div class="mt-10">
      <a
        href="https://k-artel.pro/#others"
        target="_blank"
        rel="noopener"
        class="btn-secondary group inline-flex items-center gap-3 rounded-full px-7 py-3.5 text-[12px] uppercase tracking-[var(--tracking-cap)]"
      >
        <span>История верфи</span>
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" class="transition-transform group-hover:translate-x-0.5">
          <path d="M2 10 L10 2 M10 2 H4 M10 2 V8" stroke="currentColor" stroke-width="1.4" />
        </svg>
      </a>
    </div>

    <!-- BLOCK 2 — Heritage & Legacy: video + story -->
    <div class="mt-20 border-t border-[var(--color-grey)] pt-16">
      <div class="grid grid-cols-12 gap-x-10 gap-y-8">
        <div class="col-span-12 lg:col-span-7">
          <div
            data-siberian-video
            class="group relative block aspect-video w-full overflow-hidden rounded-[2px] bg-[var(--color-ink)]"
          >
            <video
              data-video-el
              src="video/siberian.mp4"
              poster="video/siberian-poster.jpg"
              preload="metadata"
              playsinline
              class="absolute inset-0 h-full w-full object-cover"
            ></video>

            <!-- Overlay (badges + play). Hidden once playback starts. -->
            <div data-video-overlay class="pointer-events-none absolute inset-0 transition-opacity duration-500">
              <div
                class="absolute inset-0"
                style="background: linear-gradient(180deg, rgba(0,0,0,0.25) 0%, rgba(0,0,0,0) 35%, rgba(0,0,0,0) 65%, rgba(0,0,0,0.55) 100%);"
              ></div>
              <span
                class="absolute left-5 top-5 inline-flex items-center gap-2 rounded-[2px] border border-[color-mix(in_srgb,white_45%,transparent)] px-3 py-1.5 text-[10px] uppercase tracking-[var(--tracking-cap)] text-[var(--color-paper)] backdrop-blur-md"
              >
                <span class="h-1.5 w-1.5 rounded-full bg-[var(--color-paper)]"></span>
                {copy.videoChip}
              </span>
              <span class="absolute bottom-5 left-5 text-[10px] uppercase tracking-[var(--tracking-wide-cap)] text-[color-mix(in_srgb,white_70%,transparent)]">
                {copy.videoCaption}
              </span>
            </div>

            <button
              type="button"
              data-video-play
              aria-label="Play video"
              class="absolute inset-0 m-auto flex h-20 w-20 items-center justify-center rounded-full border border-[color-mix(in_srgb,white_60%,transparent)] bg-[color-mix(in_srgb,black_40%,transparent)] text-[var(--color-paper)] backdrop-blur-md transition-all duration-300 hover:scale-110 hover:border-[var(--color-paper)] hover:bg-[var(--color-paper)] hover:text-[var(--color-ink)]"
            >
              <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
                <path d="M8 5 L20 12 L8 19 Z" />
              </svg>
            </button>
          </div>
        </div>

        <div class="col-span-12 lg:col-span-5">
          <p class="eyebrow">{copy.legacyEyebrow}</p>
          <h3 class="display mt-4 text-[28px] leading-[1.1] text-[var(--color-ink)] sm:text-[34px]">
            {copy.legacyTitle}
          </h3>
          <p class="mt-5 text-[15px] leading-[1.7] text-[var(--color-deep-grey)]">{copy.legacyBody1}</p>
          <p class="mt-3 text-[15px] leading-[1.7] text-[var(--color-deep-grey)]">{copy.legacyBody2}</p>

          <div class="mt-6 grid grid-cols-2 gap-px bg-[var(--color-grey)]">
            {copy.legacyChips.map((c) => (
              <div class="bg-[var(--color-bone)] p-4">
                <p class="text-[10px] uppercase tracking-[var(--tracking-wide-cap)] text-[var(--color-fog)]">
                  {c.label}
                </p>
                <p class="mt-1 text-[14px] text-[var(--color-ink)]">{c.value}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>

    <!-- BLOCK 3 — Strategic Partnership (RGO) -->
    <div class="mt-20 border-t border-[var(--color-grey)] pt-16">
      <!-- Eyebrow with compass icon -->
      <div class="flex items-center gap-3">
        <span class="flex h-9 w-9 items-center justify-center rounded-full border border-[var(--color-ink)] text-[var(--color-ink)]">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1" />
            <path d="M8 3 L9.5 8 L8 13 L6.5 8 Z" fill="currentColor" />
            <circle cx="8" cy="8" r="0.8" fill="var(--color-bone)" />
          </svg>
        </span>
        <p class="text-[11px] uppercase tracking-[var(--tracking-wide-cap)] text-[var(--color-ink)]">
          {copy.partnerEyebrow}
        </p>
      </div>

      <h2
        class="display mt-6 text-[36px] leading-[1.05] text-[var(--color-ink)] sm:text-[48px]"
      >
        {copy.partnerTitle}
      </h2>

      <div class="mt-12 grid grid-cols-12 gap-x-10 gap-y-10">
        <!-- LEFT: body + stats -->
        <div class="col-span-12 lg:col-span-6">
          <p class="text-[15px] leading-[1.7] text-[var(--color-deep-grey)]">
            {copy.partnerBody}
          </p>

          <div class="mt-10 grid grid-cols-3 gap-6 border-y border-[var(--color-grey)] py-6 sm:gap-10 sm:py-8">
            {copy.partnerStats.map((s, i) => (
              <div class={i > 0 ? "border-l border-[var(--color-grey)] pl-6 sm:pl-10" : ""}>
                <p class="display text-[26px] font-medium leading-[1] text-[var(--color-ink)] sm:text-[32px]">
                  {s.value}
                </p>
                <p class="mt-2 text-[10px] uppercase leading-[1.3] tracking-[var(--tracking-cap)] text-[var(--color-deep-grey)] sm:text-[11px]">
                  {s.label}
                </p>
              </div>
            ))}
          </div>
        </div>

        <!-- RIGHT: Forbes quote + rgo.ru button -->
        <div class="col-span-12 lg:col-span-6">
          <figure class="rounded-[2px] border border-[var(--color-ink)] p-6 sm:p-8">
            <blockquote class="text-[14px] italic leading-[1.55] text-[var(--color-ink)] sm:text-[15px]">
              «{copy.forbesQuote}»
            </blockquote>
            <figcaption class="mt-4 text-[10px] uppercase tracking-[var(--tracking-wide-cap)] text-[var(--color-fog)]">
              — {copy.forbesAttr}
            </figcaption>
          </figure>

          <a
            href="https://rgo.ru"
            target="_blank"
            rel="noopener"
            class="btn-secondary group mt-5 inline-flex w-full items-center justify-between gap-3 rounded-[2px] px-6 py-4 text-[12px] uppercase tracking-[var(--tracking-cap)]"
          >
            <span>{copy.rgoCta}</span>
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
              <path d="M3 11 L11 3 M11 3 H5 M11 3 V9" stroke="currentColor" stroke-width="1.4" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLElement>("[data-siberian-video]").forEach((root) => {
    const video = root.querySelector<HTMLVideoElement>("[data-video-el]");
    const overlay = root.querySelector<HTMLElement>("[data-video-overlay]");
    const playBtn = root.querySelector<HTMLButtonElement>("[data-video-play]");
    if (!video || !overlay || !playBtn) return;

    const hideOverlay = () => {
      overlay.style.opacity = "0";
      playBtn.style.opacity = "0";
      playBtn.style.pointerEvents = "none";
    };
    const showOverlay = () => {
      overlay.style.opacity = "1";
      playBtn.style.opacity = "1";
      playBtn.style.pointerEvents = "auto";
    };

    playBtn.addEventListener("click", () => {
      video.controls = true;
      video.play();
    });
    video.addEventListener("play", hideOverlay);
    video.addEventListener("pause", showOverlay);
    video.addEventListener("ended", showOverlay);
  });
</script>
