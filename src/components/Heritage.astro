---
import ResponsiveImage from "./ResponsiveImage.astro";
interface Props {
  lang?: "ru" | "en";
}
const { lang = "ru" } = Astro.props;

const copy = lang === "ru"
  ? {
      // Block 1 — Корабельная Артель intro
      eyebrow: "Корабельная Артель · 1992",
      title: "30 лет на Волге.",
      body:
        "Верфь основана в Саратове в 1992 году. За три десятилетия — десятки уникальных судов, спроектированных, построенных и спущенных на воду собственными силами.",
      vesselsKicker: "Примеры спроектированных и построенных судов",
      vessels: [
        { name: "Borei 62", type: "Корабли класса люкс", photo: "heritage/borei-62.jpg" },
        { name: "Poseidon 90", type: "Экспедиционные корабли", photo: "heritage/poseidon-90.jpg" },
        { name: "Calypso 65", type: "Круизеры", photo: "heritage/calypso-65.jpg" },
        { name: "Piligrim 65", type: "Траулеры", photo: "heritage/piligrim-65.jpg" },
      ],
      // Block 2 — Heritage & Legacy
      legacyEyebrow: "Наследие и история",
      legacyTitle: "От «Сибирского Исследователя» к вашему проекту.",
      legacyBody1Html:
        'История проекта началась в суровых водах Енисея. Наш предыдущий проект, <em>«Сибирский исследователь», был создан для РГО</em>.',
      legacyBody2:
        "Мы применили тот же бескомпромиссный инженерный подход: корпус из стали для прохождения льдов, автономность на недели вперёд и технологии выживания.",
      legacyBody3:
        "Expedition 65 Lux — гражданская версия экспедиционного судна. Роскошь, защищённая бронёй.",
      legacyChips: [
        { label: "Надёжность", value: "Технологии РГО" },
        { label: "Статус", value: "Экспедиционный класс" },
      ],
      videoChip: "Проект-предшественник",
      videoCaption: "Сибирский Исследователь · 2 мин",
      videoNote: "Видео загружается",
      // Block 3 — Strategic Partnership (RGO)
      partnerEyebrow: "Стратегическое партнёрство · EST. 1845",
      partnerTitle: "Русское географическое общество",
      partnerBody:
        "Флагман «Сибирский исследователь» — 18-метровый стальной корабль класса «река-море», созданный на наших стапелях для выполнения миссий РГО в высоких широтах Арктики.",
      partnerStats: [
        { value: "18м", label: "Длина судна" },
        { value: "09Г2С", label: "Нержавеющая сталь" },
        { value: "1300", label: "Миль автономии" },
      ],
      forbesQuote:
        "Особенность судна — защитные накладки, усиливающие киль вдвое. Это позволяет работать в условиях сложной навигации, недоступных для обычных яхт.",
      forbesAttr: "Forbes Russia",
      rgoCta: "Проект на rgo.ru",
    }
  : {
      eyebrow: "Korabelnaya Artel · 1992",
      title: "30 years on the Volga.",
      body:
        "Shipyard founded in Saratov in 1992. Three decades — dozens of unique vessels, designed, built and launched in-house.",
      vesselsKicker: "Examples of vessels we've designed and built",
      vessels: [
        { name: "Borei 62", type: "Luxury-class vessels", photo: "heritage/borei-62.jpg" },
        { name: "Poseidon 90", type: "Expedition vessels", photo: "heritage/poseidon-90.jpg" },
        { name: "Calypso 65", type: "Cruisers", photo: "heritage/calypso-65.jpg" },
        { name: "Piligrim 65", type: "Trawlers", photo: "heritage/piligrim-65.jpg" },
      ],
      legacyEyebrow: "Heritage & Legacy",
      legacyTitle: "From the Siberian Explorer to your project.",
      legacyBody1Html:
        'The project began in the harsh waters of the Yenisei. Our previous build, <em>Siberian Explorer, was made for the Russian Geographical Society</em>.',
      legacyBody2:
        "We applied the same uncompromising engineering: steel hull for breaking through ice, autonomy for weeks ahead, survival-grade technology.",
      legacyBody3:
        "Expedition 65 Lux — the civilian version of an expedition vessel. Luxury protected by armor.",
      legacyChips: [
        { label: "Reliability", value: "RGS-grade build" },
        { label: "Status", value: "Expedition class" },
      ],
      videoChip: "Predecessor Project",
      videoCaption: "Siberian Explorer · 2 min",
      videoNote: "Video loading",
      partnerEyebrow: "Strategic Partnership · EST. 1845",
      partnerTitle: "Russian Geographical Society",
      partnerBody:
        "Flagship Siberian Explorer — an 18-metre steel river-sea class vessel built on our slipways for RGS missions in the high Arctic.",
      partnerStats: [
        { value: "18m", label: "Vessel length" },
        { value: "09G2S", label: "Stainless steel hull" },
        { value: "1300", label: "Nautical miles" },
      ],
      forbesQuote:
        "A distinguishing feature of the vessel is the protective overlays that double the keel strength. This allows it to work in complex navigation conditions inaccessible to ordinary yachts.",
      forbesAttr: "Forbes Russia",
      rgoCta: "Project on rgo.ru",
    };
---

<section id="heritage" class="border-t border-[var(--color-grey)] bg-[var(--color-paper)] py-16 sm:pt-[120px] sm:pb-[120px]">
  <div class="mx-auto max-w-[1440px] px-8">
    <!-- BLOCK 1 — Корабельная Артель intro + vessels -->
    <div>
      <p class="eyebrow">{copy.eyebrow}</p>
      <hr class="rule-ink mt-2 sm:mt-4" />
      <h2 class="display mt-6 text-[28px] leading-[1.05] text-[var(--color-ink)] sm:text-[48px]">
        {copy.title}
      </h2>
      <p class="mt-6 max-w-[640px] text-[14px] leading-[1.65] text-[var(--color-deep-grey)] sm:text-[15px]">
        {copy.body}
      </p>
      <p class="mt-8 text-[11px] uppercase tracking-[var(--tracking-wide-cap)] text-[var(--color-neon-blue)]">
        {copy.vesselsKicker}
      </p>
    </div>

    <!-- Vessel grid — photo card with caption strip below. -->
    <div class="mt-4 grid grid-cols-2 gap-3 sm:grid-cols-4 sm:gap-4">
      {copy.vessels.map((v) => (
        <article class="relative flex flex-col border border-[var(--color-grey)] bg-[var(--color-paper)] p-5 sm:p-6">
          <!-- Blue top accent strip — matches the Locations cards -->
          <span class="absolute inset-x-0 top-0 h-[3px] bg-[var(--color-neon-blue)]"></span>
          <div class="aspect-[5/4] w-full">
            <ResponsiveImage
              src={v.photo}
              alt={v.name}
              width={2400}
              height={1498}
              sizes="(min-width: 1024px) 25vw, (min-width: 640px) 50vw, 100vw"
              loading="lazy"
              class="h-full w-full object-contain"
            />
          </div>
          <div class="mt-4">
            <p class="text-[10px] uppercase tracking-[var(--tracking-wide-cap)] text-[var(--color-fog)]">
              {v.type}
            </p>
            <h3 class="display mt-1 text-[20px] leading-[1.1] text-[var(--color-ink)] sm:text-[22px]">
              {v.name}
            </h3>
          </div>
        </article>
      ))}
    </div>

    <!-- History CTA — links to the Kartel shipyard site -->
    <div class="mt-10">
      <a
        href="https://k-artel.pro/#others"
        target="_blank"
        rel="noopener"
        class="btn-secondary group inline-flex items-center gap-3 rounded-full px-7 py-3.5 text-[12px] uppercase tracking-[var(--tracking-cap)]"
      >
        <span>История верфи</span>
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" class="transition-transform group-hover:translate-x-0.5">
          <path d="M2 10 L10 2 M10 2 H4 M10 2 V8" stroke="currentColor" stroke-width="1.4" />
        </svg>
      </a>
    </div>

    <!-- BLOCK 2 — Heritage & Legacy: video + story -->
    <div class="mt-[120px]">
      <!-- Mobile-only: eyebrow + title above the video.
           On sm+ these live in the RIGHT column of the grid (below). -->
      <div class="mb-6 sm:hidden">
        <p class="eyebrow">{copy.legacyEyebrow}</p>
        <hr class="rule-ink mt-2" />
        <h3 class="display mt-6 text-[28px] leading-[1.1] text-[var(--color-ink)]">
          {copy.legacyTitle}
        </h3>
      </div>

      <div class="grid grid-cols-12 gap-x-4 sm:gap-x-10 gap-y-8">
        <div class="col-span-12 lg:col-span-7">
          <div
            data-siberian-video
            class="group relative block aspect-[4/3] w-full overflow-hidden rounded-[2px] bg-[var(--color-ink)] sm:aspect-video"
          >
            <video
              data-video-el
              poster="video/siberian-poster.jpg"
              preload="metadata"
              playsinline
              class="absolute inset-0 h-full w-full object-cover"
            >
              <source
                src="https://github.com/Nlefterova/Houseboat-website/releases/download/videos-v1/siberian.mp4"
                type="video/mp4"
              />
            </video>

            <!-- Overlay (badges + play). Hidden once playback starts. -->
            <div data-video-overlay class="pointer-events-none absolute inset-0 transition-opacity duration-500">
              <div
                class="absolute inset-0"
                style="background: linear-gradient(180deg, rgba(0,0,0,0.25) 0%, rgba(0,0,0,0) 35%, rgba(0,0,0,0) 65%, rgba(0,0,0,0.55) 100%);"
              ></div>
              <span
                class="absolute left-5 top-5 inline-flex items-center gap-2 rounded-[2px] border border-[color-mix(in_srgb,white_45%,transparent)] px-3 py-1.5 text-[10px] uppercase tracking-[var(--tracking-cap)] text-[var(--color-paper)] backdrop-blur-md"
              >
                <span class="h-1.5 w-1.5 rounded-full bg-[var(--color-paper)]"></span>
                {copy.videoChip}
              </span>
              <span class="absolute bottom-5 left-5 text-[10px] uppercase tracking-[var(--tracking-wide-cap)] text-[color-mix(in_srgb,white_70%,transparent)]">
                {copy.videoCaption}
              </span>
            </div>

            <button
              type="button"
              data-video-play
              aria-label="Play video"
              class="absolute inset-0 m-auto flex h-20 w-20 items-center justify-center rounded-full border border-[color-mix(in_srgb,white_60%,transparent)] bg-[color-mix(in_srgb,black_40%,transparent)] text-[var(--color-paper)] backdrop-blur-md transition-all duration-300 hover:scale-110 hover:border-[var(--color-paper)] hover:bg-[var(--color-paper)] hover:text-[var(--color-ink)]"
            >
              <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
                <path d="M8 5 L20 12 L8 19 Z" />
              </svg>
            </button>
          </div>
        </div>

        <div class="col-span-12 flex flex-col lg:col-span-5">
          <!-- Original eyebrow + rule + title. Hidden on mobile (shown above the video). -->
          <div class="hidden sm:block">
            <p class="eyebrow">{copy.legacyEyebrow}</p>
            <hr class="rule-ink mt-2 sm:mt-4" />
            <h3 class="display mt-6 text-[28px] leading-[1.1] text-[var(--color-ink)] sm:text-[34px]">
              {copy.legacyTitle}
            </h3>
          </div>

          <!-- Body paragraphs. Order 2 on mobile (after chips), 2 on desktop (after title). -->
          <div class="order-2 mt-6 sm:mt-0">
            <p class="heritage-body mt-5 text-[15px] leading-[1.7] text-[var(--color-deep-grey)]" set:html={copy.legacyBody1Html}></p>
            <p class="mt-3 text-[15px] leading-[1.7] text-[var(--color-deep-grey)]">{copy.legacyBody2}</p>
            <p class="mt-6 text-[15px] font-semibold leading-[1.7] text-[var(--color-ink)]">{copy.legacyBody3}</p>
          </div>

          <!-- Chips. Order 1 on mobile (right under the video), order 3 on desktop (bottom). -->
          <div class="order-1 mt-0 grid grid-cols-2 gap-3 sm:order-3 sm:mt-8">
            {copy.legacyChips.map((c) => (
              <div class="relative border border-[var(--color-grey)] bg-[var(--color-paper)] px-4 py-3">
                <span class="absolute inset-x-0 top-0 h-[2px] bg-[var(--color-neon-blue)]"></span>
                <p class="eyebrow">{c.label}</p>
                <p class="mt-1.5 text-[13px] font-medium text-[var(--color-ink)] sm:text-[14px]">{c.value}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>

    <!-- BLOCK 3 — Strategic Partnership (RGO) -->
    <div class="mt-16 sm:mt-[120px]">
      <!-- Eyebrow with compass icon -->
      <p class="eyebrow">{copy.partnerEyebrow}</p>
      <hr class="rule-ink mt-2 sm:mt-4" />

      <h2
        class="display mt-6 text-[28px] leading-[1.05] text-[var(--color-ink)] sm:text-[48px]"
      >
        {copy.partnerTitle}
      </h2>

      <!-- Body + Forbes quote as peers (claim ↔ third-party proof). Quote
           gets a neon-blue left rule so it reads as third-party, not body. -->
      <div class="mt-6 grid grid-cols-12 gap-x-4 sm:mt-12 sm:gap-x-10 gap-y-8">
        <p class="col-span-12 text-[15px] leading-[1.7] text-[var(--color-deep-grey)] lg:col-span-6">
          {copy.partnerBody}
        </p>
        <figure class="col-span-12 border-l-2 border-[var(--color-neon-blue)] pl-5 lg:col-span-6">
          <blockquote class="text-[14px] italic leading-[1.6] text-[var(--color-neon-blue)] sm:text-[15px]">
            «{copy.forbesQuote}»
          </blockquote>
          <figcaption class="mt-3 text-[11px] font-medium uppercase tracking-[var(--tracking-cap)] text-[var(--color-ink)]">
            — {copy.forbesAttr}
          </figcaption>
        </figure>
      </div>

      <!-- Fact strip + rgo.ru button, separated from the body block by a hairline rule. -->
      <div class="mt-10 border-t border-[var(--color-grey)] pt-8">
        <div class="flex flex-col items-start gap-8 sm:flex-row sm:items-end sm:justify-between sm:gap-12">
          <div class="grid w-full grid-cols-3 gap-6 sm:w-auto sm:gap-12">
            {copy.partnerStats.map((s) => (
              <div>
                <p class="display text-[22px] font-medium leading-[1] text-[var(--color-ink)] sm:text-[28px]">
                  {s.value}
                </p>
                <p class="mt-2 text-[10px] uppercase leading-[1.3] tracking-[var(--tracking-cap)] text-[var(--color-deep-grey)] sm:text-[11px]">
                  {s.label}
                </p>
              </div>
            ))}
          </div>

          <a
            href="https://rgo.ru"
            target="_blank"
            rel="noopener"
            class="btn-secondary group inline-flex shrink-0 items-center gap-2 rounded-full px-7 py-3.5 text-[12px] uppercase tracking-[var(--tracking-cap)]"
          >
            <span>{copy.rgoCta}</span>
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" class="transition-transform group-hover:translate-x-0.5">
              <path d="M2 10 L10 2 M10 2 H4 M10 2 V8" stroke="currentColor" stroke-width="1.4" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLElement>("[data-siberian-video]").forEach((root) => {
    const video = root.querySelector<HTMLVideoElement>("[data-video-el]");
    const overlay = root.querySelector<HTMLElement>("[data-video-overlay]");
    const playBtn = root.querySelector<HTMLButtonElement>("[data-video-play]");
    if (!video || !overlay || !playBtn) return;

    const hideOverlay = () => {
      overlay.style.opacity = "0";
      playBtn.style.opacity = "0";
      playBtn.style.pointerEvents = "none";
    };
    const showOverlay = () => {
      overlay.style.opacity = "1";
      playBtn.style.opacity = "1";
      playBtn.style.pointerEvents = "auto";
    };

    playBtn.addEventListener("click", () => {
      video.controls = true;
      video.play();
    });
    video.addEventListener("play", hideOverlay);
    video.addEventListener("pause", showOverlay);
    video.addEventListener("ended", showOverlay);
  });
</script>

<style>
  /* Highlight phrase in legacy body — neon-blue, medium weight, not italic. */
  .heritage-body :global(em) {
    font-style: normal;
    color: var(--color-neon-blue);
    font-weight: 500;
  }
</style>
