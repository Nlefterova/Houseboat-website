---
interface Props {
  lang?: "ru" | "en";
}
const { lang = "ru" } = Astro.props;

const copy = lang === "ru"
  ? {
      eyebrow: "Внешний вид",
      title: "Галерея",
      lede:
        "Expedition 65 Lux на воде, на стапелях, на закате — реальные фотографии судна.",
      expandLabel: "Открыть",
    }
  : {
      eyebrow: "Exterior",
      title: "Gallery",
      lede:
        "Expedition 65 Lux on the water, at the yard, at dusk — real photographs of the vessel.",
      expandLabel: "Expand",
    };

// Each cell:
//   Mobile: Tailwind aspect-[X/Y] for proportional height (col-span-12 → full width)
//   Desktop (sm:): explicit pixel heights so bottoms align perfectly across the mosaic
//   The tall photo [03] uses row-span-2 + sm:h-auto so it stretches to match (280 + gap + 280) on the right
const photos = [
  {
    tint: "linear-gradient(135deg, #2a3640 0%, #131a21 60%, #06090b 100%)",
    labelRu: "На воде · профиль",
    labelEn: "On water · profile",
    classes: "aspect-[16/9] col-span-12 sm:col-span-5 sm:aspect-auto sm:h-[280px]",
  },
  {
    tint: "linear-gradient(135deg, #20303a 0%, #131a21 60%, #06090b 100%)",
    labelRu: "Аэровид · корма",
    labelEn: "Aerial · stern",
    classes: "aspect-[21/9] col-span-12 sm:col-span-7 sm:aspect-auto sm:h-[280px]",
  },
  {
    tint: "linear-gradient(135deg, #3a3320 0%, #1d1813 60%, #0a0805 100%)",
    labelRu: "На зимней стоянке",
    labelEn: "Winter dock",
    classes:
      "aspect-[4/5] col-span-12 sm:col-span-5 sm:row-span-2 sm:aspect-auto sm:h-auto",
  },
  {
    tint: "linear-gradient(135deg, #2a2a2a 0%, #161616 60%, #060606 100%)",
    labelRu: "Палуба · кормовая",
    labelEn: "Stern deck",
    classes: "aspect-[21/9] col-span-12 sm:col-span-7 sm:aspect-auto sm:h-[280px]",
  },
  {
    tint: "linear-gradient(135deg, #1f2a32 0%, #0e1418 55%, #06090b 100%)",
    labelRu: "Палуба · носовая",
    labelEn: "Bow deck",
    classes: "aspect-[21/9] col-span-12 sm:col-span-7 sm:aspect-auto sm:h-[280px]",
  },
];
---

<section id="exterior" class="bg-[var(--color-paper)] py-12 sm:py-16">
  <div class="mx-auto max-w-[1440px] px-8">
    <!-- Header (compact) -->
    <div class="grid grid-cols-12 gap-x-8 gap-y-4 pb-6">
      <div class="col-span-12 lg:col-span-5">
        <p class="eyebrow">{copy.eyebrow}</p>
        <hr class="rule-ink mt-4" />
        <h2
          class="display mt-6 text-[32px] leading-[1.05] text-[var(--color-ink)] sm:text-[44px]"
        >
          {copy.title}
        </h2>
      </div>
      <div class="col-span-12 lg:col-span-7 lg:pt-2">
        <p class="max-w-xl text-[14px] leading-[1.6] text-[var(--color-deep-grey)]">
          {copy.lede}
        </p>
      </div>
    </div>

    <!-- Single grid: 8px gap drives every distance (horizontal + vertical, top-row, mid-rows, between stacked).
         Desktop heights are explicit so the left tall photo (row-span-2) ends exactly at the right column's bottom. -->
    <div class="grid grid-cols-12 gap-2">
      {photos.map((p, i) => (
        <button
          type="button"
          aria-label={copy.expandLabel}
          class={`group relative overflow-hidden rounded-[2px] text-left ${p.classes}`}
          style={`background: ${p.tint};`}
        >
          <!-- Placeholder label, bottom-left -->
          <span class="absolute bottom-3 left-4 text-[10px] uppercase tracking-[var(--tracking-wide-cap)] text-[color-mix(in_srgb,white_55%,transparent)]">
            [{String(i + 1).padStart(2, "0")}] {lang === "ru" ? p.labelRu : p.labelEn}
          </span>

          <!-- Expand affordance, top-right -->
          <span
            class="absolute right-3 top-3 flex h-8 w-8 items-center justify-center rounded-[2px] border border-[color-mix(in_srgb,white_30%,transparent)] bg-[color-mix(in_srgb,black_35%,transparent)] text-[var(--color-paper)] opacity-70 backdrop-blur-md transition-all duration-200 group-hover:opacity-100 group-hover:border-[color-mix(in_srgb,white_70%,transparent)] group-hover:bg-[color-mix(in_srgb,black_55%,transparent)]"
            aria-hidden="true"
          >
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
              <path
                d="M2 7 V10 H5 M10 5 V2 H7 M2 10 L5 7 M10 2 L7 5"
                stroke="currentColor"
                stroke-width="1.2"
                stroke-linecap="square"
              />
            </svg>
          </span>
        </button>
      ))}
    </div>
  </div>
</section>
