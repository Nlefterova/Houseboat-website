      },
    ];
---

<section id="spec" class="bg-[var(--color-paper)] py-12 sm:py-16">
  <div class="mx-auto max-w-[1440px] px-8">
    <!-- Header (matches other sections) + CTA button on the right -->
    <div class="grid grid-cols-12 items-end gap-x-8 gap-y-6 pb-8">
      <div class="col-span-12 lg:col-span-7">
        <p class="eyebrow">{copy.eyebrow}</p>
        <hr class="rule-ink mt-4" />
        <h2
          class="display mt-6 text-[32px] leading-[1.05] text-[var(--color-ink)] sm:text-[44px]"
        >
          {copy.title}
        </h2>
        <p class="mt-6 max-w-2xl text-[14px] leading-[1.6] text-[var(--color-deep-grey)]">
          {copy.lede}
        </p>
      </div>
      <div class="col-span-12 lg:col-span-5 lg:text-right">
        <button
          type="button"
          data-fullspec-open
          class="group inline-flex items-center gap-3 rounded-full bg-[var(--color-ink)] px-7 py-3.5 text-[12px] uppercase tracking-[var(--tracking-cap)] text-[var(--color-paper)] transition-colors hover:bg-[var(--color-deep-grey)]"
        >
          <span>{copy.fullSpecCta}</span>
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" class="transition-transform group-hover:translate-x-0.5">
            <path d="M2 10 L10 2 M10 2 H4 M10 2 V8" stroke="currentColor" stroke-width="1.4" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Brief spec table — label left, value right, thin grey rules between rows -->
    <dl class="border-t border-[var(--color-grey)]">
      {rows.map((r) => (
        <div
          class="grid grid-cols-12 gap-x-8 gap-y-1 border-b border-[var(--color-grey)] py-2.5 sm:py-3"
        >
          <dt
            class="col-span-12 text-[12px] uppercase tracking-[var(--tracking-cap)] text-[var(--color-ink)] sm:col-span-5"
          >
            {r.label}
          </dt>
          <dd
            class="col-span-12 text-[14px] leading-[1.35] text-[var(--color-fog)] sm:col-span-7 sm:text-[15px]"
          >
            {r.value}
          </dd>
        </div>
      ))}
    </dl>
  </div>
</section>

<!-- Full specification modal — opens on CTA click. Same Bering-style overlay
     pattern as the Layouts fullscreen: fixed inset, body scroll lock, ESC to close. -->
<div
  data-fullspec-modal
  class="fullspec-modal fixed inset-0 z-50 hidden flex-col bg-[var(--color-paper)]"
  aria-hidden="true"
  role="dialog"
  aria-modal="true"
  aria-labelledby="fullspec-title"
>
  <!-- Header: title + close button -->
  <div
    class="flex items-start justify-between gap-6 border-b border-[var(--color-grey)] px-6 py-6 sm:px-10 sm:py-8"
  >
    <div>
      <p class="eyebrow">{copy.eyebrow}</p>
      <h2
        id="fullspec-title"
        class="display mt-3 text-[26px] leading-[1.05] text-[var(--color-ink)] sm:text-[36px]"
      >
        {copy.fullSpecTitle}
      </h2>
      <p class="mt-2 text-[12px] uppercase tracking-[var(--tracking-cap)] text-[var(--color-fog)]">
        {copy.fullSpecSubtitle}
      </p>
    </div>
    <button
      type="button"
      data-fullspec-close
      class="inline-flex shrink-0 items-center gap-2 rounded-full bg-[var(--color-ink)] px-5 py-2.5 text-[11px] uppercase tracking-[var(--tracking-cap)] text-[var(--color-paper)] transition-colors hover:bg-[var(--color-deep-grey)]"
    >
      <span>{copy.closeLabel}</span>
      <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
        <path d="M2 2 L10 10 M10 2 L2 10" stroke="currentColor" stroke-width="1.2" stroke-linecap="square" />
      </svg>
    </button>
  </div>

  <!-- Category nav as pill chips. -->
  <nav
    aria-label="Sections"
    class="border-b border-[var(--color-grey)] bg-[var(--color-paper)] px-6 py-4 sm:px-10 sm:py-5"
  >
    <ul class="flex flex-wrap gap-2">
      {fullSpec.map((group, i) => (
        <li>
          <button
            type="button"
            data-fullspec-jump={`spec-cat-${i}`}
            class="rounded-full bg-[var(--color-light-grey)] px-4 py-2 text-[11px] uppercase tracking-[var(--tracking-cap)] text-[var(--color-deep-grey)] transition-colors hover:bg-[var(--color-ink)] hover:text-[var(--color-paper)]"
          >
            {group.category}
          </button>
        </li>
      ))}
    </ul>
  </nav>

  <!-- Scrollable body: categorized spec rows -->
  <div data-fullspec-body class="flex-1 overflow-y-auto px-6 py-8 sm:px-10 sm:py-10">
    <div class="mx-auto max-w-[1100px] space-y-10">
      {fullSpec.map((group, i) => (
        <section id={`spec-cat-${i}`} class="scroll-mt-6">
          <h3
            data-fullspec-section-title
            class="text-[11px] uppercase tracking-[var(--tracking-cap)] text-[var(--color-deep-grey)] transition-colors"
          >
            {group.category}
          </h3>
          <hr class="rule-ink mt-2" />
          <dl class="mt-1 border-t border-[var(--color-grey)]">
            {group.rows.map((r) => (
              <div
                class="grid grid-cols-12 gap-x-6 gap-y-1 border-b border-[var(--color-grey)] py-2 sm:py-2.5"
              >
                <dt
                  class="col-span-12 text-[13px] leading-[1.4] text-[var(--color-ink)] sm:col-span-9"
                >
                  {r.label}
                </dt>
                <dd
                  class="col-span-12 text-[13px] leading-[1.35] text-[var(--color-fog)] sm:col-span-3 sm:text-right sm:text-[14px]"
                >
                  {r.value}
                </dd>
              </div>
            ))}
          </dl>
        </section>
      ))}
    </div>
  </div>
</div>

<style>
  .fullspec-modal.is-open {
    display: flex;
  }
  .fullspec-modal [data-fullspec-jump].is-active-pill {
    background-color: var(--color-ink);
    color: var(--color-paper);
  }
  .fullspec-modal [data-fullspec-section-title].is-active-title {
    font-weight: 600;
    color: var(--color-ink);
  }
</style>

<script>
  const modal = document.querySelector<HTMLElement>("[data-fullspec-modal]");
  const body = modal?.querySelector<HTMLElement>("[data-fullspec-body]");
  const openBtns = document.querySelectorAll<HTMLButtonElement>("[data-fullspec-open]");
  const closeBtns = document.querySelectorAll<HTMLButtonElement>("[data-fullspec-close]");
  const jumpBtns = Array.from(
    document.querySelectorAll<HTMLButtonElement>("[data-fullspec-jump]")
  );
  const sections = body
    ? Array.from(body.querySelectorAll<HTMLElement>('section[id^="spec-cat-"]'))
    : [];
  const titles = sections.map((s) =>
    s.querySelector<HTMLElement>("[data-fullspec-section-title]")
  );

  function setActive(idx: number) {
    jumpBtns.forEach((b, i) =>
      b.classList.toggle("is-active-pill", i === idx)
    );
    titles.forEach((t, i) =>
      t?.classList.toggle("is-active-title", i === idx)
    );
  }

  function open() {
    if (!modal) return;
    modal.classList.add("is-open");
    modal.setAttribute("aria-hidden", "false");
    document.body.style.overflow = "hidden";
    if (body) body.scrollTop = 0;
    setActive(0);
    closeBtns[0]?.focus();
  }

  function close() {
    if (!modal) return;
    modal.classList.remove("is-open");
    modal.setAttribute("aria-hidden", "true");
    document.body.style.overflow = "";
  }

  openBtns.forEach((b) => b.addEventListener("click", open));
  closeBtns.forEach((b) => b.addEventListener("click", close));

  jumpBtns.forEach((b, idx) => {
    b.addEventListener("click", () => {
      const id = b.dataset.fullspecJump;
      if (!id || !body) return;
      const target = body.querySelector<HTMLElement>(`#${id}`);
      if (!target) return;
      // getBoundingClientRect is reliable even when offsetParent isn't the scroll container.
      const top =
        target.getBoundingClientRect().top -
        body.getBoundingClientRect().top +
        body.scrollTop -
        24;
      body.scrollTo({ top, behavior: "smooth" });
      setActive(idx);
    });
  });

  // Sync active pill + bolded title with whichever section is currently at the top.
  if (body && sections.length > 0) {
    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((e) => e.isIntersecting)
          .map((e) => ({
            el: e.target as HTMLElement,
            top: e.target.getBoundingClientRect().top,
          }))
          .sort((a, b) => a.top - b.top);
        if (visible.length === 0) return;
        const idx = sections.indexOf(visible[0].el);
        if (idx >= 0) setActive(idx);
      },
      { root: body, rootMargin: "0px 0px -70% 0px", threshold: 0 }
    );
    sections.forEach((s) => observer.observe(s));
  }

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && modal?.classList.contains("is-open")) {
      close();
    }
  });
</script>
