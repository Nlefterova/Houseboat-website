---
interface Props {
  lang?: "ru" | "en";
  solid?: boolean;
}
const { lang = "ru", solid = false } = Astro.props;

// Nav mirrors the actual sections on the page (in scroll order).
// Hero has no anchor (top of page). Заявка is the CTA pill on the right.
const nav = lang === "ru"
  ? [
      { label: "Обзор", href: "#overview" },
      { label: "Экстерьер", href: "#exterior" },
      { label: "Интерьер", href: "#interior" },
      { label: "Палубы", href: "#layouts" },
      { label: "Спецификация", href: "#spec" },
      { label: "Локации", href: "#locations" },
      { label: "Наследие", href: "#heritage" },
    ]
  : [
      { label: "Overview", href: "#overview" },
      { label: "Exterior", href: "#exterior" },
      { label: "Interior", href: "#interior" },
      { label: "Layouts", href: "#layouts" },
      { label: "Specs", href: "#spec" },
      { label: "Locations", href: "#locations" },
      { label: "Heritage", href: "#heritage" },
    ];

const ctaLabel = lang === "ru" ? "Связаться с верфью" : "Contact the Shipyard";
const menuLabel = lang === "ru" ? "Меню" : "Menu";
const closeLabel = lang === "ru" ? "Закрыть" : "Close";
---

<!-- Sticky header. Two visual states toggled via `data-scrolled`:
       (default)  transparent over hero, light text
       (scrolled) paper bg + shadow, dark text, condensed padding
     `solid` prop forces the scrolled state on pages without a hero (e.g. /privacy). -->
<header
  data-sticky-header
  data-scrolled={solid ? "" : undefined}
  class="group/sticky fixed inset-x-0 top-0 z-50 transition-[background-color,box-shadow] duration-300 data-[scrolled]:bg-[var(--color-paper)] data-[scrolled]:shadow-[0_4px_20px_-8px_rgba(0,0,0,0.15)]"
>
  <div class="mx-auto flex max-w-[1440px] items-center justify-between px-4 pt-3 pb-6 transition-[padding] duration-300 group-data-[scrolled]/sticky:pb-3 md:px-6">
    <a
      href={lang === "en" ? "en/" : "./"}
      data-logo-link
      class="group/logo flex items-center gap-2 text-[var(--color-paper)] transition-colors duration-300 hover:text-[var(--color-neon-blue)] group-data-[scrolled]/sticky:text-[var(--color-ink)] group-data-[scrolled]/sticky:hover:text-[var(--color-neon-blue)] md:gap-3"
      aria-label="KARTEL Boats — Expedition 65 Lux"
    >
      <svg
        viewBox="173 197 300 32"
        class="h-6 w-auto sm:h-7"
        fill="currentColor"
        aria-hidden="true"
      >
        <path d="M471.931 228.998H427.547L434.284 197.295H440.624L435.225 222.658H473.269L471.931 228.998Z" />
        <path d="M426.605 203.636H388.561L384.499 222.658H422.543L421.206 228.998H383.162C378.935 228.998 377.267 226.885 378.159 222.658L382.221 203.636C383.112 199.408 385.672 197.295 389.899 197.295H427.943L426.605 203.636ZM423.881 216.317H392.178L393.565 209.976H425.268L423.881 216.317Z" />
        <path d="M332.833 197.295H377.218L375.88 203.636H356.858L351.459 228.998H345.118L350.518 203.636H331.496L332.833 197.295Z" />
        <path d="M281.711 228.998H275.371L282.108 197.295H320.152C324.379 197.295 326.046 199.408 325.155 203.636L323.817 209.976C322.893 214.203 320.35 216.317 316.189 216.317H309.749L319.755 228.998H311.83L301.823 216.317H290.727L292.114 209.976H317.477L318.814 203.636H287.111L281.711 228.998Z" />
        <path d="M230.986 228.998H224.645L230.045 203.636C230.937 199.408 233.496 197.295 237.723 197.295H269.426C273.653 197.295 275.321 199.408 274.43 203.636L269.03 228.998H262.689L265.364 216.317H240.002L241.389 209.976H266.751L268.089 203.636H236.386L230.986 228.998Z" />
        <path d="M186.998 197.295L180.261 228.998H173.92L180.657 197.295H186.998ZM189.97 213.147L214.738 197.295H225.042L200.274 213.147L218.305 228.998H208.001L189.97 213.147Z" />
      </svg>
      <span class="hidden flex-col leading-tight sm:flex">
        <span class="text-[10px] font-light uppercase tracking-[var(--tracking-wide-cap)] text-[color-mix(in_srgb,white_55%,transparent)] transition-colors duration-300 group-hover/logo:text-[var(--color-neon-blue)] group-data-[scrolled]/sticky:text-[var(--color-fog)] md:text-[11px]">
          Expedition
        </span>
        <span class="text-[15px] font-bold uppercase tracking-tight text-[var(--color-paper)] transition-colors duration-300 group-hover/logo:text-[var(--color-neon-blue)] group-data-[scrolled]/sticky:text-[var(--color-ink)] md:text-[17px]">
          65&nbsp;Lux
        </span>
      </span>
    </a>

    <!-- Desktop nav (≥xl).
         Two visual channels:
           – hover  → text turns neon-blue (color flip)
           – active → tiny neon-blue bar appears below the label (position cue)
         Independent on purpose so the active item can also be hovered and you
         can still tell which is which. -->
    <nav class="hidden items-center gap-5 xl:flex 2xl:gap-8">
      {nav.map((item) => (
        <a
          href={item.href}
          class="relative text-[10px] font-bold tracking-[var(--tracking-cap)] uppercase text-[color-mix(in_srgb,white_75%,transparent)] transition-colors duration-300 hover:text-[var(--color-neon-blue)] group-data-[scrolled]/sticky:text-[var(--color-deep-grey)] group-data-[scrolled]/sticky:hover:text-[var(--color-neon-blue)] after:absolute after:left-1/2 after:-bottom-2 after:h-[2px] after:w-3 after:-translate-x-1/2 after:rounded-full after:bg-[var(--color-neon-blue)] after:opacity-0 after:transition-opacity after:duration-300 after:content-[''] aria-[current=page]:after:opacity-100"
        >
          {item.label}
        </a>
      ))}
    </nav>

    <!-- Desktop CTA (≥xl) -->
    <a
      href="#inquire"
      class="hidden shrink-0 items-center whitespace-nowrap rounded-full border border-[color-mix(in_srgb,white_50%,transparent)] bg-[color-mix(in_srgb,black_40%,transparent)] px-5 py-2.5 text-[10px] font-bold uppercase tracking-[var(--tracking-cap)] text-[var(--color-paper)] backdrop-blur-md transition-colors duration-300 hover:border-[var(--color-neon-blue)] hover:bg-[var(--color-neon-blue)] group-data-[scrolled]/sticky:border-[var(--color-neon-blue)] group-data-[scrolled]/sticky:bg-[var(--color-neon-blue)] group-data-[scrolled]/sticky:text-[var(--color-paper)] group-data-[scrolled]/sticky:backdrop-blur-none xl:inline-flex"
    >
      {ctaLabel}
    </a>

    <!-- Mobile hamburger (<xl) -->
    <button
      type="button"
      data-mobile-menu-open
      aria-label={menuLabel}
      aria-controls="mobile-menu"
      aria-expanded="false"
      class="flex h-10 w-10 items-center justify-center text-[var(--color-paper)] transition-colors duration-300 group-data-[scrolled]/sticky:text-[var(--color-ink)] xl:hidden"
    >
      <svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
        <path d="M3 6 H19 M3 11 H19 M3 16 H19" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
      </svg>
    </button>
  </div>

  <!-- Mobile drawer (off-canvas from right) -->
  <div
    id="mobile-menu"
    data-mobile-menu
    class="pointer-events-none fixed inset-0 z-[60] opacity-0 transition-opacity duration-300 data-[open]:pointer-events-auto data-[open]:opacity-100 xl:hidden"
    aria-hidden="true"
  >
    <!-- Backdrop -->
    <div data-mobile-menu-close class="absolute inset-0 bg-[color-mix(in_srgb,black_85%,transparent)] backdrop-blur-sm"></div>

    <!-- Panel -->
    <div class="absolute inset-y-0 right-0 flex w-[85%] max-w-[360px] flex-col bg-[var(--color-ink)] px-6 pt-6 pb-10 text-[var(--color-paper)] shadow-2xl">
      <div class="flex items-center justify-between">
        <span class="text-[11px] uppercase tracking-[var(--tracking-wide-cap)] text-[var(--color-fog)]">{menuLabel}</span>
        <button
          type="button"
          data-mobile-menu-close
          aria-label={closeLabel}
          class="flex h-10 w-10 items-center justify-center text-[var(--color-paper)]"
        >
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
            <path d="M3 3 L15 15 M15 3 L3 15" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
          </svg>
        </button>
      </div>

      <nav class="mt-10 flex flex-col gap-5">
        {nav.map((item) => (
          <a
            href={item.href}
            data-mobile-menu-link
            class="text-[18px] font-medium uppercase tracking-[0.02em] text-[var(--color-paper)] transition-colors hover:text-[var(--color-neon-blue)]"
          >
            {item.label}
          </a>
        ))}
      </nav>

      <a
        href="#inquire"
        data-mobile-menu-link
        class="mt-12 inline-flex items-center justify-center rounded-full bg-[var(--color-neon-blue)] px-6 py-4 text-[12px] font-semibold uppercase tracking-[var(--tracking-cap)] text-[var(--color-paper)]"
      >
        {ctaLabel}
      </a>
    </div>
  </div>
</header>

<script>
  const header = document.querySelector<HTMLElement>("[data-sticky-header]");
  // `solid` pages mount with data-scrolled already set; never toggle on those.
  const lockedSolid = header?.hasAttribute("data-scrolled");

  function updateScrollState() {
    if (!header || lockedSolid) return;
    // Flip to scrolled state once user has cleared ~70% of the viewport height.
    // Cheap and robust — no IntersectionObserver / hero sentinel needed.
    const threshold = window.innerHeight * 0.7;
    if (window.scrollY > threshold) {
      header.setAttribute("data-scrolled", "");
    } else {
      header.removeAttribute("data-scrolled");
    }
  }

  window.addEventListener("scroll", updateScrollState, { passive: true });
  window.addEventListener("resize", updateScrollState, { passive: true });
  updateScrollState();

  // === Logo: smooth-scroll to top when already on home ===
  // Normal anchor navigation otherwise (e.g. clicking from /privacy/).
  const logoLink = document.querySelector<HTMLAnchorElement>("[data-logo-link]");
  logoLink?.addEventListener("click", (e) => {
    const baseEl = document.querySelector("base");
    const baseHref = baseEl?.getAttribute("href") || "/";
    const basePath = new URL(baseHref, location.href).pathname;
    const norm = (p: string) => p.replace(/\/+$/, "") || "/";
    if (norm(location.pathname) === norm(basePath)) {
      e.preventDefault();
      window.scrollTo({ top: 0, behavior: "smooth" });
    }
  });

  // === Scroll-spy: stamp aria-current="page" on the nav item whose
  // section is crossing the viewport's upper third. Narrow rootMargin
  // window means at most one section is "current" at a time. ===
  const navAnchors = Array.from(
    document.querySelectorAll<HTMLAnchorElement>('header nav a[href^="#"]')
  );
  const sectionToAnchors = new Map<string, HTMLAnchorElement[]>();
  navAnchors.forEach((a) => {
    const id = a.getAttribute("href")?.slice(1);
    if (!id) return;
    if (!sectionToAnchors.has(id)) sectionToAnchors.set(id, []);
    sectionToAnchors.get(id)!.push(a);
  });
  const trackedSections = Array.from(sectionToAnchors.keys())
    .map((id) => document.getElementById(id))
    .filter((el): el is HTMLElement => el !== null);

  if (trackedSections.length > 0) {
    const spy = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const id = entry.target.id;
          sectionToAnchors.forEach((anchors, key) => {
            anchors.forEach((a) => {
              if (key === id) a.setAttribute("aria-current", "page");
              else a.removeAttribute("aria-current");
            });
          });
        });
      },
      { rootMargin: "-30% 0px -65% 0px", threshold: 0 }
    );
    trackedSections.forEach((s) => spy.observe(s));
  }

  // Mobile drawer
  const menu = document.querySelector<HTMLElement>("[data-mobile-menu]");
  const opener = document.querySelector<HTMLButtonElement>("[data-mobile-menu-open]");
  const closers = document.querySelectorAll<HTMLElement>("[data-mobile-menu-close]");
  const links = document.querySelectorAll<HTMLAnchorElement>("[data-mobile-menu-link]");

  function openMenu() {
    if (!menu || !opener) return;
    menu.setAttribute("data-open", "");
    menu.setAttribute("aria-hidden", "false");
    opener.setAttribute("aria-expanded", "true");
    document.body.style.overflow = "hidden";
  }
  function closeMenu() {
    if (!menu || !opener) return;
    menu.removeAttribute("data-open");
    menu.setAttribute("aria-hidden", "true");
    opener.setAttribute("aria-expanded", "false");
    document.body.style.overflow = "";
  }

  opener?.addEventListener("click", openMenu);
  closers.forEach((b) => b.addEventListener("click", closeMenu));
  links.forEach((l) => l.addEventListener("click", closeMenu));
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && menu?.hasAttribute("data-open")) closeMenu();
  });
</script>
