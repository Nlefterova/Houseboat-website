---
interface Props {
  lang?: "ru" | "en";
}
const { lang = "ru" } = Astro.props;

// Nav mirrors the actual sections on the page (in scroll order).
// Hero has no anchor (top of page). Заявка is the CTA pill on the right.
const nav = lang === "ru"
  ? [
      { label: "Обзор", href: "#overview" },
      { label: "Экстерьер", href: "#exterior" },
      { label: "Интерьер", href: "#interior" },
      { label: "Палубы", href: "#layouts" },
      { label: "Спецификация", href: "#spec" },
      { label: "Наследие", href: "#heritage" },
      { label: "Локации", href: "#locations" },
    ]
  : [
      { label: "Overview", href: "#overview" },
      { label: "Exterior", href: "#exterior" },
      { label: "Interior", href: "#interior" },
      { label: "Layouts", href: "#layouts" },
      { label: "Specs", href: "#spec" },
      { label: "Heritage", href: "#heritage" },
      { label: "Locations", href: "#locations" },
    ];

const ctaLabel = lang === "ru" ? "Связаться с верфью" : "Contact the Shipyard";
---

<header class="absolute inset-x-0 top-0 z-50">
  <div class="mx-auto flex max-w-[1440px] items-center justify-between px-4 pt-3 pb-6 md:px-6">
    <a
      href={lang === "en" ? "/en/" : "/"}
      class="group flex items-center gap-2 text-[var(--color-paper)] md:gap-3"
      aria-label="KARTEL Boats — Expedition 65 Lux"
    >
      <svg
        viewBox="173 197 300 32"
        class="h-6 w-auto sm:h-7"
        fill="currentColor"
        aria-hidden="true"
      >
        <path d="M471.931 228.998H427.547L434.284 197.295H440.624L435.225 222.658H473.269L471.931 228.998Z" />
        <path d="M426.605 203.636H388.561L384.499 222.658H422.543L421.206 228.998H383.162C378.935 228.998 377.267 226.885 378.159 222.658L382.221 203.636C383.112 199.408 385.672 197.295 389.899 197.295H427.943L426.605 203.636ZM423.881 216.317H392.178L393.565 209.976H425.268L423.881 216.317Z" />
        <path d="M332.833 197.295H377.218L375.88 203.636H356.858L351.459 228.998H345.118L350.518 203.636H331.496L332.833 197.295Z" />
        <path d="M281.711 228.998H275.371L282.108 197.295H320.152C324.379 197.295 326.046 199.408 325.155 203.636L323.817 209.976C322.893 214.203 320.35 216.317 316.189 216.317H309.749L319.755 228.998H311.83L301.823 216.317H290.727L292.114 209.976H317.477L318.814 203.636H287.111L281.711 228.998Z" />
        <path d="M230.986 228.998H224.645L230.045 203.636C230.937 199.408 233.496 197.295 237.723 197.295H269.426C273.653 197.295 275.321 199.408 274.43 203.636L269.03 228.998H262.689L265.364 216.317H240.002L241.389 209.976H266.751L268.089 203.636H236.386L230.986 228.998Z" />
        <path d="M186.998 197.295L180.261 228.998H173.92L180.657 197.295H186.998ZM189.97 213.147L214.738 197.295H225.042L200.274 213.147L218.305 228.998H208.001L189.97 213.147Z" />
      </svg>
      <span class="flex flex-col leading-tight">
        <span class="text-[10px] font-light uppercase tracking-[var(--tracking-wide-cap)] text-[color-mix(in_srgb,white_55%,transparent)] md:text-[11px]">
          Expedition
        </span>
        <span class="text-[15px] font-bold uppercase tracking-tight text-[var(--color-paper)] md:text-[17px]">
          65&nbsp;Lux
        </span>
      </span>
    </a>

    <nav class="hidden items-center gap-10 md:flex">
      {nav.map((item) => (
        <a
          href={item.href}
          class="text-[10px] font-bold tracking-[var(--tracking-cap)] uppercase text-[color-mix(in_srgb,white_75%,transparent)] transition-colors hover:text-[var(--color-neon-blue)]"
        >
          {item.label}
        </a>
      ))}
    </nav>

    <a
      href="#inquire"
      class="group inline-flex shrink-0 items-center gap-2 whitespace-nowrap rounded-full border border-[color-mix(in_srgb,white_50%,transparent)] bg-[color-mix(in_srgb,black_40%,transparent)] px-5 py-2.5 text-[10px] font-bold uppercase tracking-[var(--tracking-cap)] text-[var(--color-paper)] backdrop-blur-md transition-colors hover:border-[var(--color-neon-blue)] hover:bg-[var(--color-neon-blue)]"
    >
      <span>{ctaLabel}</span>
      <svg width="12" height="12" viewBox="0 0 12 12" fill="none" class="transition-transform group-hover:translate-x-0.5">
        <path d="M2 10 L10 2 M10 2 H4 M10 2 V8" stroke="currentColor" stroke-width="1.4" />
      </svg>
    </a>
  </div>
</header>
