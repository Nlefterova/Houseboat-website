---
import "../styles/global.css";
import Header from "../components/Header.astro";

interface Props {
  title?: string;
  description?: string;
  lang?: "ru" | "en";
}

const {
  title = "Expedition 65 Lux — Право на свободу маршрута · KARTEL",
  description = "Автономное судно Expedition 65 Lux для покорения северных широт. Корпус из нержавеющей стали, тик, дуб и технологии выживания.",
  lang = "ru",
} = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <!-- Anchor relative paths to the site root regardless of URL trailing slash.
         Force trailing slash so the base reads as a directory, not a file. -->
    <base href={import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + "/"} />
    <link rel="icon" type="image/svg+xml" href="favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
    />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <Header lang={lang} />
    <main><slot /></main>
  </body>
</html>
