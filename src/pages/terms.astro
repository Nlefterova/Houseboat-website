---
import LegalPage from "../components/LegalPage.astro";

/**
 * Условия использования сайта — adapted from a standard Shopify TOS template
 * into a Russian marketing/lead-generation context. The original 20-section
 * template covered ordering, refunds, products, billing — none of which
 * apply to expedition65.ru (a marketing site, not a store). This version is
 * trimmed to ~12 sections that cover what actually matters:
 *   – Site content accuracy
 *   – IP / copyright
 *   – Contact-form use
 *   – Prohibited uses
 *   – Third-party links
 *   – Governing law (RF)
 *
 * ⚠️ LEGAL — TO BE REVIEWED BY COUNSEL BEFORE LAUNCH.
 * Same disclaimer as /privacy: competent draft, not legal advice.
 */

const sections = [
  // OVERVIEW
  {
    id: "overview",
    number: "ОБЗОР",
    title: "",
    body: `
      <p>Настоящие Условия использования («Условия») регулируют доступ и использование сайта <a href="https://expedition65.ru">expedition65.ru</a> («Сайт»), принадлежащего KARTEL Boats («мы», «Оператор»).</p>
