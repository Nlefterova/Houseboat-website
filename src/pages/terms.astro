  // SECTION 3
  {
    id: "form",
    number: "РАЗДЕЛ 3",
    title: "ФОРМА ОБРАТНОЙ СВЯЗИ",
    body: `
      <p>При заполнении формы обратной связи на Сайте вы:</p>
