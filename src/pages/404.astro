---
/**
 * 404 — Point Nemo.
 *
 * Full-bleed AI-generated video of a nautical channel marker buoy in a stormy
 * open ocean. Video normally hosted on GitHub Releases (out of the deploy
 * artifact); the local path below is a dev-preview swap that gets replaced
 * with the Releases URL right before merging to main.
 *
 * No JavaScript, no canvas. Semantic <main>/<h1>/<p> structure with hidden
 * screen-reader context; decorative background is aria-hidden. The video
 * is replaced with the static poster for prefers-reduced-motion users.
 */

const SITE_URL = "https://expedition65.ru";
const VIDEO_URL =
  "https://github.com/Nlefterova/Houseboat-website/releases/download/nemo-video-v1/point-nemo-loop.mp4";

const POSTER_URL = "video/point-nemo-poster.jpg";

const baseHref = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : import.meta.env.BASE_URL + "/";

const OG_TITLE = "404 — Точка Немо · Expedition 65 Lux";
const OG_DESCRIPTION =
  "Вы достигли точки Немо — самой отдалённой точки мирового океана.";
const OG_IMAGE = `${SITE_URL}/video/point-nemo-poster.jpg`;
const CANONICAL = `${SITE_URL}/404/`;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href={baseHref} />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="canonical" href={CANONICAL} />
    <title>{OG_TITLE}</title>
    <meta name="description" content={OG_DESCRIPTION} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={OG_TITLE} />
    <meta property="og:description" content={OG_DESCRIPTION} />
    <meta property="og:url" content={CANONICAL} />
    <meta property="og:image" content={OG_IMAGE} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="690" />
    <meta property="og:locale" content="ru_RU" />
    <meta property="og:site_name" content="KARTEL · Expedition 65 Lux" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={OG_TITLE} />
    <meta name="twitter:description" content={OG_DESCRIPTION} />
    <meta name="twitter:image" content={OG_IMAGE} />

    <link rel="icon" type="image/svg+xml" href="favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
    />
    <style>
      :root {
        --nemo-fg: #eef4f6;
        --nemo-fg-soft: #ced7dc;
        --nemo-fg-mute: #a8b3ba;
        --nemo-fg-dim: #8992a0;
        --nemo-bg: #04070a;
      }
      html,
      body {
        margin: 0;
        padding: 0;
        height: 100%;
        background: var(--nemo-bg);
        overflow: hidden;
        font-family: "Helvetica Now Display", "Inter", -apple-system,
          BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      }
      * {
        box-sizing: border-box;
      }
      /* Reset browser default margins on the semantic elements we use so the
         explicit spacing in .nemo-404 / .nemo-headline / .nemo-sub / .nemo-coords
         is what actually lands. */
      main,
      h1,
      p {
        margin: 0;
        padding: 0;
      }

      .nemo-stage {
        position: fixed;
        inset: 0;
        overflow: hidden;
      }

      #nemo-video {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
      }

      .nemo-scrim {
        position: absolute;
        inset: 0;
        pointer-events: none;
        background:
          linear-gradient(
            to bottom,
            rgba(4, 8, 12, 0.6) 0%,
            rgba(4, 8, 12, 0.22) 30%,
            rgba(4, 8, 12, 0) 55%,
            rgba(4, 8, 12, 0.3) 85%,
            rgba(4, 8, 12, 0.65) 100%
          );
      }

      .nemo-copy {
        position: absolute;
        inset: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding-top: 6vh;
        pointer-events: none;
        text-align: center;
        z-index: 6;
        margin: 0;
      }
      .nemo-404 {
        font-weight: 700;
        letter-spacing: 0.02em;
        line-height: 0.9;
        font-size: clamp(120px, 23vw, 340px);
        color: var(--nemo-fg);
        text-shadow:
          0 0 120px rgba(0, 0, 0, 0.75),
          0 0 60px rgba(120, 160, 180, 0.22),
          0 6px 40px rgba(0, 0, 0, 0.95);
        margin: 0;
      }
      .nemo-headline {
        margin: 18px 0 0;
        font-weight: 500;
        letter-spacing: 0.42em;
        text-transform: uppercase;
        font-size: clamp(15px, 2vw, 26px);
        color: var(--nemo-fg-soft);
        padding-left: 0.42em;
        text-shadow:
          0 0 40px rgba(0, 0, 0, 0.85),
          0 2px 20px rgba(0, 0, 0, 0.95);
      }
      .nemo-sub {
        margin: 14px 0 0;
        font-style: italic;
        font-weight: 300;
        font-size: clamp(13px, 1.4vw, 17px);
        color: var(--nemo-fg-mute);
        letter-spacing: 0.04em;
        text-shadow:
          0 0 30px rgba(0, 0, 0, 0.85),
          0 2px 16px rgba(0, 0, 0, 0.95);
      }
      .nemo-coords {
        margin: 24px 0 0;
        font-weight: 400;
        font-size: clamp(12px, 1.15vw, 15px);
        letter-spacing: 0.34em;
        color: var(--nemo-fg-dim);
        text-shadow:
          0 0 26px rgba(0, 0, 0, 0.85),
          0 2px 14px rgba(0, 0, 0, 0.95);
      }

      .nemo-foot {
        position: absolute;
        left: 0;
        right: 0;
        bottom: 5.5vh;
        display: flex;
        justify-content: center;
        z-index: 6;
      }
      .nemo-cta {
        pointer-events: auto;
        font-weight: 500;
        letter-spacing: 0.28em;
        text-transform: uppercase;
        font-size: 13px;
        color: var(--nemo-fg);
        text-decoration: none;
        padding: 13px 30px;
        border: 1px solid rgba(180, 195, 205, 0.4);
        border-radius: 2px;
        background: rgba(6, 12, 18, 0.55);
        backdrop-filter: blur(2px);
        -webkit-backdrop-filter: blur(2px);
        transition:
          border-color 0.3s ease,
          color 0.3s ease,
          background-color 0.3s ease;
      }
      .nemo-cta:hover,
      .nemo-cta:focus-visible {
        border-color: var(--color-neon-blue, #0047bb);
        color: #eef4f7;
        background: rgba(14, 24, 36, 0.65);
        outline: none;
      }
      .nemo-cta:focus-visible {
        outline: 2px solid var(--color-neon-blue, #0047bb);
        outline-offset: 3px;
      }

      /* Respect user motion preferences — swap the autoplaying loop for the
         static poster so reduced-motion users get the same imagery without
         movement. */
      @media (prefers-reduced-motion: reduce) {
        #nemo-video {
          display: none;
        }
        .nemo-stage {
          background:
            var(--nemo-bg)
            url("video/point-nemo-poster.jpg")
            center / cover no-repeat;
        }
      }
    </style>
  </head>
  <body>
    <main class="nemo-stage">
      <video
        id="nemo-video"
        autoplay
        loop
        muted
        playsinline
        preload="metadata"
        poster={POSTER_URL}
        aria-hidden="true"
      >
        <source src={VIDEO_URL} type="video/mp4" />
      </video>
      <div class="nemo-scrim" aria-hidden="true"></div>

      <div class="nemo-copy">
        <h1 class="nemo-404" aria-label="Ошибка 404">404</h1>
        <p class="nemo-headline">Вы достигли точки Немо</p>
        <p class="nemo-sub">самая отдалённая точка мирового океана</p>
        <p
          class="nemo-coords"
          aria-label="Координаты: 48 градусов 52.6 минут южной широты, 123 градуса 23.6 минут западной долготы"
        >
          48°52.6′ Ю.Ш. &nbsp;·&nbsp; 123°23.6′ З.Д.
        </p>
      </div>

      <div class="nemo-foot">
        <a href="./" class="nemo-cta">Вернуться в гавань</a>
      </div>
    </main>
  </body>
</html>
